# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "JetBrainsMono Nerd Font"
font-style = Regular
font-size = 9

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 14
confirm-close-surface = false
window-show-tab-bar = never

gtk-toolbar-style = flat

resize-overlay = never

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Quick terminal
quick-terminal-position = top
quick-terminal-size = 38%
quick-terminal-autohide = false
keybind = global:super+backquote=toggle_quick_terminal
keybind = global:f12=toggle_quick_terminal

# Splits with tmux-like prefix (ctrl+space)
keybind = ctrl+space>v=new_split:right
keybind = ctrl+space>s=new_split:down
keybind = ctrl+space>h=goto_split:left
keybind = ctrl+space>j=goto_split:down
keybind = ctrl+space>k=goto_split:up
keybind = ctrl+space>l=goto_split:right
keybind = ctrl+space>shift+arrow_left=resize_split:left,10
keybind = ctrl+space>shift+arrow_down=resize_split:down,10
keybind = ctrl+space>shift+arrow_up=resize_split:up,10
keybind = ctrl+space>shift+arrow_right=resize_split:right,10
keybind = ctrl+space>z=toggle_split_zoom
keybind = ctrl+space>x=close_surface
keybind = ctrl+space>==equalize_splits

# Quality of life
keybind = ctrl+shift+p=toggle_command_palette

# Existing clipboard bindings
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard

# Existing resize bindings (large steps)
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100

# Existing mouse scroll tuning
mouse-scroll-multiplier = 0.95

# Fix general slowness on Hyprland
async-backend = epoll
