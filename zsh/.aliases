# Aliases e funções pessoais do Dias

alias c='clear'           # omarchy tem c='opencode'
alias o='opencode'
alias phpshell='/usr/bin/php -a'

unalias art 2>/dev/null
unalias sail 2>/dev/null
art() {
  local dir="$PWD"

  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/artisan" ]]; then
      (cd "$dir" && php artisan "$@")
      return
    fi

    dir="$(dirname "$dir")"
  done

  echo "art: não encontrei artisan neste projeto"
  return 1
}

_art_completion() {
  local lastParam flagPrefix requestComp out comp quote i w
  local -a completions

  words=("${=words[1,CURRENT]}")
  lastParam=${words[-1]}

  setopt local_options BASH_REMATCH

  if [[ "${lastParam}" =~ '-.*=' ]]; then
    flagPrefix="-P ${BASH_REMATCH}"
  fi

  requestComp="${words[0]} ${words[1]} _complete --no-interaction -szsh -a1 -c$((CURRENT - 1))"

  for w in ${words[@]}; do
    w=$(printf -- '%b' "$w")
    quote="${w:0:1}"

    if [[ "$quote" = "'" ]]; then
      w="${w%\'}"
      w="${w#\'}"
    elif [[ "$quote" = '"' ]]; then
      w="${w%\"}"
      w="${w#\"}"
    fi

    if [[ -n "$w" ]]; then
      i="${i}-i${w} "
    fi
  done

  if [[ -z "$i" ]]; then
    requestComp="${requestComp} -i\" \""
  else
    requestComp="${requestComp} ${i}"
  fi

  out=$(eval SHELL_VERBOSITY=0 ${requestComp} 2>/dev/null)

  while IFS=$'\n' read -r comp; do
    if [[ -n "$comp" ]]; then
      comp=${comp//:/\\:}
      local tab=$(printf '\t')
      comp=${comp//$tab/:}
      completions+=${comp}
    fi
  done < <(printf "%s\n" "${out[@]}")

  eval _describe "completions" completions $flagPrefix
  return $?
}

if (( $+functions[compdef] )); then
  compdef _art_completion art
fi

sail() {
  local dir="$PWD"

  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/vendor/bin/sail" ]]; then
      (cd "$dir" && sh vendor/bin/sail "$@")
      return
    fi

    if [[ -f "$dir/sail" ]]; then
      (cd "$dir" && sh sail "$@")
      return
    fi

    dir="$(dirname "$dir")"
  done

  echo "sail: não encontrei vendor/bin/sail neste projeto"
  return 1
}

# Sync manual Sync <-> Dropbox
alias sync-now='unison /home/dias/Sync/Logseq /home/dias/Dropbox/Logseq -auto -batch -prefer newer && unison obsidian && echo "Sync completo!"'
alias sync-check='unison /home/dias/Sync/Logseq /home/dias/Dropbox/Logseq -batch && unison /home/dias/Sync/Obsidian /home/dias/Dropbox/Obsidian -batch'

# Atalho para criar/entrar em sessões tmux
# Uso: t [nome]  →  sem nome abre/retoma sessão "main"
unalias t 2>/dev/null
t() {
  local name
  if [[ "$1" == "." ]]; then
    name="$(basename "$PWD")"
  else
    name="${1:-main}"
  fi
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$name" 2>/dev/null || tmux new-session -d -s "$name" \; switch-client -t "$name"
  else
    tmux attach -t "$name" 2>/dev/null || tmux new -s "$name"
  fi
}

# Selector de sessões sesh (Alt+S)
function sesh-sessions() {
  {
    exec </dev/tty
    exec <&1
    local session
    session=$(sesh list -t -c | fzf --height 40% --reverse --border-label ' sesh ' --border --prompt '⚡  ')
    zle reset-prompt > /dev/null 2>&1 || true
    [[ -z "$session" ]] && return
    sesh connect $session
  }
}

# Abrir ficheiro markdown no Typora
md() { typora "$@" </dev/null >/dev/null 2>&1 &! }

# Abrir Microsoft Teams numa janela Chromium isolada
teams() {
  local dir="$HOME/.config/chromium-teams"
  mkdir -p "$dir"
  chromium \
    --user-data-dir="$dir" \
    --disable-gpu \
    --ozone-platform=x11 \
    --app="https://teams.microsoft.com/v2" \
    </dev/null >/dev/null 2>&1 &!
}

# Override do open do Omarchy: desligar do terminal sem perder sessão Wayland
open() {
  local mimetype
  mimetype=$(xdg-mime query filetype "$1" 2>/dev/null)
  case "$1" in
    *.md) typora "$@" </dev/null >/dev/null 2>&1 &! ;;
    *)
      case "$mimetype" in
        text/*) nvim "$@" ;;
        *)      xdg-open "$@" </dev/null >/dev/null 2>&1 &! ;;
      esac
      ;;
  esac
}

# Ajuda contextual git
ghelp() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Não estás dentro de um repositório git."
    echo ""
    echo "  git clone <url>       → copiar um repo existente"
    echo "  git init              → criar um repo novo aqui"
    return
  fi

  local status
  status=$(git status --porcelain 2>/dev/null)

  local branch
  branch=$(git branch --show-current 2>/dev/null)

  local is_worktree=false
  local worktree_dir
  worktree_dir=$(basename "$PWD")
  [[ "$worktree_dir" == *"--"* ]] && is_worktree=true

  local has_changes=false
  local has_untracked=false
  [[ -n "$status" ]] && has_changes=true
  echo "$status" | grep -q "^??" && has_untracked=true

  local ahead
  ahead=$(git rev-list @{u}..HEAD 2>/dev/null | wc -l | tr -d ' ')

  echo "── Estado atual ──────────────────────────"
  echo "  Branch: $branch"
  $is_worktree && echo "  (estás numa worktree)"
  echo ""

  if $has_changes; then
    echo "  Tens alterações por guardar:"
    git status --short
    echo ""
    echo "── O que usar agora ──────────────────────"
    echo "  gcam 'descrição'   → guardar todas as alterações com mensagem"
    echo "  gcad               → corrigir a mensagem do último commit"
    if $has_untracked; then
      echo ""
      echo "  Nota: tens ficheiros novos (??). O gcam inclui-os automaticamente"
      echo "  se fizeres  git add <ficheiro>  primeiro, ou ignora-os se não precisares."
    fi
  else
    echo "  Repo limpo — nada por guardar."
    echo ""
    echo "── O que usar agora ──────────────────────"
    if [[ "$ahead" -gt 0 ]]; then
      echo "  git push           → enviar $ahead commit(s) para o servidor"
    else
      echo "  Tudo sincronizado. Podes editar ficheiros e depois usar:"
      echo "  gcam 'descrição'   → guardar alterações quando estiveres pronto"
    fi
  fi

  if $is_worktree; then
    echo ""
    echo "  gd                 → remover esta worktree quando acabares"
  else
    echo ""
    echo "  ga <nome>          → criar uma cópia isolada do projeto para experimentar algo"
  fi
  echo "──────────────────────────────────────────"
}
