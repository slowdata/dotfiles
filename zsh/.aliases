# Aliases e funcoes pessoais do Dias
# Sobrepoem-se aos defaults do Omarchy carregados no .zshrc

# c = limpar terminal (omarchy tem c='opencode')
unalias c 2>/dev/null
alias c='clear'

# o = opencode (liberta o c para clear)
alias o='opencode'

# t = tmux smart: retoma sessao existente ou cria nova
# Uso: t [nome]  ->  sem nome usa "main"; t . usa o nome do dir atual
unalias t 2>/dev/null
t() {
  local name
  if [[ "$1" == "." ]]; then
    name="$(basename "$PWD")"
  else
    name="${1:-main}"
  fi
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$name" 2>/dev/null || tmux new-session -d -s "$name" \; switch-client -t "$name"
  else
    tmux attach -t "$name" 2>/dev/null || tmux new -s "$name"
  fi
}

# open = abre com xdg-open desligado do terminal
unset -f open 2>/dev/null
open() { xdg-open "$@" >/dev/null 2>&1 & }

# Selector de sessoes sesh (Alt+S) — o zle -N e bindkey ficam no .zshrc
function sesh-sessions() {
  {
    exec </dev/tty
    exec <&1
    local session
    session=$(sesh list -t -c | fzf --height 40% --reverse --border-label ' sesh ' --border --prompt '  ')
    zle reset-prompt > /dev/null 2>&1 || true
    [[ -z "$session" ]] && return
    sesh connect $session
  }
}

# --- Aliases pessoais nao incluidos no Omarchy ---

alias phpshell='/usr/bin/php -a'
alias art='artisan'
alias sail='sh $([ -f sail ] && echo sail || echo vendor/bin/sail)'

# Sync manual Sync <-> Dropbox
alias sync-now='unison /home/dias/Sync/Logseq /home/dias/Dropbox/Logseq -auto -batch -prefer newer && unison obsidian && echo "Sync completo!"'
alias sync-check='unison /home/dias/Sync/Logseq /home/dias/Dropbox/Logseq -batch && unison /home/dias/Sync/Obsidian /home/dias/Dropbox/Obsidian -batch'

# Abrir Microsoft Teams numa janela Chromium isolada
teams() {
  local dir="$HOME/.config/chromium-teams"
  mkdir -p "$dir"
  chromium \
    --user-data-dir="$dir" \
    --disable-gpu \
    --ozone-platform=x11 \
    --app="https://teams.microsoft.com/v2" \
    </dev/null >/dev/null 2>&1 &!
}

# Ajuda contextual git
ghelp() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Nao estas dentro de um repositorio git."
    echo ""
    echo "  git clone <url>       -> copiar um repo existente"
    echo "  git init              -> criar um repo novo aqui"
    return
  fi

  local status
  status=$(git status --porcelain 2>/dev/null)

  local branch
  branch=$(git branch --show-current 2>/dev/null)

  local is_worktree=false
  local worktree_dir
  worktree_dir=$(basename "$PWD")
  [[ "$worktree_dir" == *"--"* ]] && is_worktree=true

  local has_changes=false
  local has_untracked=false
  [[ -n "$status" ]] && has_changes=true
  echo "$status" | grep -q "^??" && has_untracked=true

  local ahead
  ahead=$(git rev-list @{u}..HEAD 2>/dev/null | wc -l | tr -d ' ')

  echo "-- Estado atual ------------------------------------------"
  echo "  Branch: $branch"
  $is_worktree && echo "  (estas numa worktree)"
  echo ""

  if $has_changes; then
    echo "  Tens alteracoes por guardar:"
    git status --short
    echo ""
    echo "-- O que usar agora --------------------------------------"
    echo "  gcam 'descricao'   -> guardar todas as alteracoes com mensagem"
    echo "  gcad               -> corrigir a mensagem do ultimo commit"
    if $has_untracked; then
      echo ""
      echo "  Nota: tens ficheiros novos (??). O gcam inclui-os automaticamente"
      echo "  se fizeres  git add <ficheiro>  primeiro, ou ignora-os se nao precisares."
    fi
  else
    echo "  Repo limpo -- nada por guardar."
    echo ""
    echo "-- O que usar agora --------------------------------------"
    if [[ "$ahead" -gt 0 ]]; then
      echo "  git push           -> enviar $ahead commit(s) para o servidor"
    else
      echo "  Tudo sincronizado. Podes editar ficheiros e depois usar:"
      echo "  gcam 'descricao'   -> guardar alteracoes quando estiveres pronto"
    fi
  fi

  if $is_worktree; then
    echo ""
    echo "  gd                 -> remover esta worktree quando acabares"
  else
    echo ""
    echo "  ga <nome>          -> criar uma copia isolada do projeto para experimentar algo"
  fi
  echo "----------------------------------------------------------"
}
