# Config específica por máquina — não versionar
.zshrc.local

# Backups/quarentena locais
_claude_backup/
_pi_backup/
_quarantine/**
**/__pycache__/
*.bak.*

# Claude Code runtime/state/secrets — não versionar
claude/.claude/.credentials.json
claude/.claude/settings.json
claude/.claude/settings.local.json
claude/.claude/history.jsonl
claude/.claude/mcp-needs-auth-cache.json
claude/.claude/backups/
claude/.claude/cache/
claude/.claude/debug/
claude/.claude/file-history/
claude/.claude/image-cache/
claude/.claude/paste-cache/
claude/.claude/projects/
claude/.claude/sessions/
claude/.claude/shell-snapshots/
claude/.claude/statsig/
claude/.claude/tasks/
claude/.claude/telemetry/
claude/.claude/todos/

# Pi agent runtime/state/secrets — não versionar
# settings.json é local por máquina; nunca versionar nem symlinkar para si próprio
pi/.pi/agent/auth.json
pi/.pi/agent/settings.json
pi/.pi/agent/settings.json.bak.*
pi/.pi/agent/sessions/
pi/.pi/agent/web-search-stats.json
pi/.pi/agent/extensions/*.bak.*
pi/.pi/agent/themes/*.bak.*
pi/.pi/agent/skills/caveman*
