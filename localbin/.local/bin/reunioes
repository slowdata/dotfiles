#!/bin/bash

set -euo pipefail

REUNIOES_DIR="${REUNIOES_DIR:-$HOME/Sync/Reunioes}"
WHISPER_MODEL_DEFAULT="${WHISPER_MODEL_DEFAULT:-large-v3}"
CHUNK_SECONDS_DEFAULT="${CHUNK_SECONDS_DEFAULT:-180}"
OPUS_BITRATE="${OPUS_BITRATE:-48k}"
KEEP_WAV_DAYS="${KEEP_WAV_DAYS:-14}"

has() { command -v "$1" >/dev/null 2>&1; }
use_gum() { has gum && [[ -t 0 && -t 1 ]] && ( : </dev/tty ) 2>/dev/null; }

style() {
  if use_gum; then gum style --foreground 212 --bold "$@"; else printf '%s\n' "$*"; fi
}

info() { printf 'ℹ️  %s\n' "$*"; }
warn() { printf '⚠️  %s\n' "$*"; }
err() { printf '❌ %s\n' "$*" >&2; }

pause() {
  echo
  if ( : </dev/tty ) 2>/dev/null; then
    read -rp "Enter para continuar..." _ </dev/tty || true
  elif [[ -t 0 ]]; then
    read -rp "Enter para continuar..." _ || true
  fi
}

confirm() {
  local prompt="$1" answer
  if use_gum; then
    gum confirm "$prompt" </dev/tty >/dev/tty
  else
    if ( : </dev/tty ) 2>/dev/null; then
      read -rp "$prompt [y/N] " answer </dev/tty
    else
      read -rp "$prompt [y/N] " answer
    fi
    [[ "${answer,,}" == "y" || "${answer,,}" == "yes" || "${answer,,}" == "s" || "${answer,,}" == "sim" ]]
  fi
}

choose() {
  local header="$1"; shift
  if use_gum; then
    # Passar opções como argumentos evita problemas de stdin/TTY em algumas versões do gum.
    # Ler de /dev/tty evita que command substitution deixe o menu sem input.
    gum choose --header "$header" --height 15 "$@" </dev/tty
  else
    local options=("$@") i opt
    echo "$header" >/dev/tty
    select opt in "${options[@]}"; do
      [[ -n "${opt:-}" ]] && { printf '%s\n' "$opt"; return 0; }
    done </dev/tty
  fi
}

input() {
  local prompt="$1" default="${2:-}" value
  if use_gum; then
    gum input --prompt "$prompt " --value "$default" </dev/tty
  else
    if ( : </dev/tty ) 2>/dev/null; then
      read -rp "$prompt [$default] " value </dev/tty
    else
      read -rp "$prompt [$default] " value
    fi
    printf '%s\n' "${value:-$default}"
  fi
}

file_base() {
  local f="$1"
  printf '%s' "${f%.*}"
}

human_size() {
  if has numfmt; then numfmt --to=iec --suffix=B "$1"; else printf '%sB' "$1"; fi
}

file_size() {
  stat -c '%s' "$1" 2>/dev/null || printf '0'
}

meeting_rows() {
  shopt -s nullglob
  local seen=() files=() f base key wav md opus size_wav size_opus saved status date name
  for f in "$REUNIOES_DIR"/reuniao_*.*; do
    [[ -f "$f" ]] || continue
    case "$f" in *.wav|*.md|*.opus) ;; *) continue;; esac
    case "${f##*/}" in *.bak-*.md|*.partial.md|*.retry*.md) continue;; esac
    base="$(file_base "$f")"
    key="${base##*/}"
    if [[ " ${seen[*]} " != *" $key "* ]]; then
      seen+=("$key")
      files+=("$base")
    fi
  done

  printf 'Data\tHora\tWAV\tMD\tOPUS\tPoupança\tBase\n'
  for base in "${files[@]}"; do
    wav="$base.wav"; md="$base.md"; opus="$base.opus"
    [[ -e "$wav" ]] && status="✅" || status="—"
    local wav_s="$status"
    [[ -e "$md" ]] && status="✅" || status="—"
    local md_s="$status"
    [[ -e "$opus" ]] && status="✅" || status="—"
    local opus_s="$status"
    saved="—"
    if [[ -e "$wav" && -e "$opus" ]]; then
      size_wav=$(file_size "$wav"); size_opus=$(file_size "$opus")
      if (( size_wav > size_opus )); then saved="$(human_size $((size_wav - size_opus)))"; fi
    fi
    name="${base##*/}"
    if [[ "$name" =~ ^reuniao_([0-9]{4}-[0-9]{2}-[0-9]{2})_([0-9]{2})([0-9]{2})$ ]]; then
      date="${BASH_REMATCH[1]}"; hour="${BASH_REMATCH[2]}:${BASH_REMATCH[3]}"
    else
      date="?"; hour="?"
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$date" "$hour" "$wav_s" "$md_s" "$opus_s" "$saved" "$name"
  done | sort
}

show_status() {
  style "Reuniões — estado"
  echo "Pasta: $REUNIOES_DIR"
  echo
  if use_gum; then
    # --print mostra a tabela e sai; sem isto o gum table fica em modo interativo.
    meeting_rows | gum table --separator $'\t' --height 25 --print
  else
    meeting_rows | column -t -s $'\t'
  fi
}

pending_transcriptions() {
  shopt -s nullglob
  local wav base
  for wav in "$REUNIOES_DIR"/*.wav "$REUNIOES_DIR"/*.opus; do
    [[ -f "$wav" ]] || continue
    base="$(file_base "$wav")"
    [[ -f "$base.md" ]] || printf '%s\n' "$wav"
  done
}

choose_audio_file() {
  local prompt="$1"
  mapfile -t files < <(pending_transcriptions)
  if (( ${#files[@]} == 0 )); then
    warn "Não há áudio pendente de transcrição."
    return 1
  fi
  choose "$prompt" "${files[@]}"
}

transcribe_pending() {
  local audio lang archive model chunks
  audio="$(choose_audio_file "Áudio para transcrever")" || { pause; return; }
  lang="$(choose "Língua" "pt" "en" "auto")"
  [[ "$lang" == "auto" ]] && lang=""
  model="$(input "Modelo" "$WHISPER_MODEL_DEFAULT")"
  chunks="$(input "Blocos segundos" "$CHUNK_SECONDS_DEFAULT")"

  archive="0"
  if confirm "Criar OPUS no fim da transcrição? (mantém WAV)"; then archive="1"; fi

  echo
  info "A transcrever: $audio"
  info "Modelo=$model Língua=${lang:-auto} Chunks=$chunks ARCHIVE_OPUS=$archive"
  echo
  if [[ -n "$lang" ]]; then
    WHISPER_MODEL="$model" WHISPER_LANGUAGE="$lang" CHUNK_SECONDS="$chunks" ARCHIVE_OPUS="$archive" transcrever-reuniao "$audio"
  else
    WHISPER_MODEL="$model" CHUNK_SECONDS="$chunks" ARCHIVE_OPUS="$archive" transcrever-reuniao "$audio"
  fi
  pause
}

all_audio_files() {
  shopt -s nullglob
  local audio
  for audio in "$REUNIOES_DIR"/*.wav "$REUNIOES_DIR"/*.opus; do
    [[ -f "$audio" ]] && printf '%s\n' "$audio"
  done | sort -r
}

choose_any_audio_file() {
  local prompt="$1"
  mapfile -t files < <(all_audio_files)
  if (( ${#files[@]} == 0 )); then
    warn "Não há ficheiros áudio em $REUNIOES_DIR."
    return 1
  fi
  choose "$prompt" "${files[@]}"
}

retranscribe_job() {
  local audio="$1" tmp_output="$2" final_output="$3" lang="$4" model="$5" chunks="$6" archive="$7"
  local backup rc=0

  info "A refazer transcrição: $audio"
  info "Output temporário: $tmp_output"
  info "Output final: $final_output"
  info "Modelo=$model Língua=${lang:-auto} Chunks=$chunks ARCHIVE_OPUS=$archive"
  echo

  if [[ -n "$lang" ]]; then
    WHISPER_MODEL="$model" WHISPER_LANGUAGE="$lang" CHUNK_SECONDS="$chunks" ARCHIVE_OPUS="$archive" transcrever-reuniao "$audio" "$tmp_output" || rc=$?
  else
    WHISPER_MODEL="$model" CHUNK_SECONDS="$chunks" ARCHIVE_OPUS="$archive" transcrever-reuniao "$audio" "$tmp_output" || rc=$?
  fi

  if (( rc != 0 )); then
    err "Transcrição falhou com código $rc. Mantido output temporário/parcial: $tmp_output"
    return "$rc"
  fi

  if [[ -f "$final_output" ]]; then
    backup="${final_output%.md}.bak-$(date +%Y%m%d-%H%M%S).md"
    mv -- "$final_output" "$backup"
    info "Transcrição anterior guardada: $backup"
  fi

  mv -- "$tmp_output" "$final_output"
  info "Transcrição refeita: $final_output"
}

retranscribe_audio() {
  local audio lang archive model chunks base final_output tmp_output log_file session cmd
  audio="$(choose_any_audio_file "Áudio para refazer transcrição")" || { pause; return; }
  base="$(file_base "$audio")"
  final_output="$base.md"
  tmp_output="$base.retry-$(date +%Y%m%d-%H%M%S).md"
  log_file="$base.retranscrever-$(date +%Y%m%d-%H%M%S).log"

  if [[ -f "$final_output" ]]; then
    warn "Já existe transcrição: $final_output"
    confirm "Refazer? A versão atual será guardada como backup" || return
  fi

  lang="$(choose "Língua" "pt" "en" "auto")"
  [[ "$lang" == "auto" ]] && lang=""
  model="$(input "Modelo" "$WHISPER_MODEL_DEFAULT")"
  chunks="$(input "Blocos segundos" "$CHUNK_SECONDS_DEFAULT")"

  archive="0"
  if [[ "$audio" == *.wav ]] && confirm "Criar/atualizar OPUS no fim? (mantém WAV)"; then archive="1"; fi

  if has tmux && confirm "Correr em background/tmux? (recomendado se estás remoto/telemóvel)"; then
    session="reunioes_refazer_$(date +%Y%m%d_%H%M%S)"
    printf -v cmd '%q ' reunioes refazer-job "$audio" "$tmp_output" "$final_output" "$lang" "$model" "$chunks" "$archive"
    tmux new-session -d -s "$session" "$cmd > $(printf '%q' "$log_file") 2>&1; echo EXIT:\$? >> $(printf '%q' "$log_file")"
    info "Job lançado em tmux: $session"
    info "Log: $log_file"
    info "Ver progresso: tail -f $(printf '%q' "$log_file")"
  else
    if ! retranscribe_job "$audio" "$tmp_output" "$final_output" "$lang" "$model" "$chunks" "$archive"; then
      err "Falhou. A transcrição anterior foi preservada. Parcial/temp: $tmp_output"
      return 1
    fi
  fi
  pause
}

archive_candidates() {
  shopt -s nullglob
  local wav base
  for wav in "$REUNIOES_DIR"/*.wav; do
    [[ -f "$wav" ]] || continue
    base="$(file_base "$wav")"
    [[ -f "$base.md" && ! -f "$base.opus" ]] && printf '%s\n' "$wav"
  done
}

make_opus() {
  local wav="$1" opus="${wav%.*}.opus"
  ffmpeg -hide_banner -loglevel error -y -i "$wav" \
    -c:a libopus -b:a "$OPUS_BITRATE" -vbr on -compression_level 10 -ac 1 \
    "$opus"
}

archive_one() {
  mapfile -t files < <(archive_candidates)
  if (( ${#files[@]} == 0 )); then
    warn "Não há WAV com MD e sem OPUS."
    pause; return
  fi
  local wav opus
  wav="$(choose "WAV para arquivar em OPUS" "${files[@]}")"
  [[ -n "$wav" ]] || return
  info "A criar OPUS: $wav"
  make_opus "$wav"
  opus="${wav%.*}.opus"
  info "Criado: $opus"
  pause
}

archive_all() {
  mapfile -t files < <(archive_candidates)
  if (( ${#files[@]} == 0 )); then
    warn "Não há WAV com MD e sem OPUS."
    pause; return
  fi
  printf '%s\n' "${files[@]}"
  echo
  confirm "Criar OPUS para ${#files[@]} ficheiro(s)?" || return
  local wav opus n=0 total=${#files[@]}
  for wav in "${files[@]}"; do
    n=$((n + 1))
    opus="${wav%.*}.opus"
    info "[$n/$total] A arquivar: $wav"
    if make_opus "$wav"; then
      info "[$n/$total] OK: $opus"
    else
      err "[$n/$total] Falhou: $wav"
      return 1
    fi
  done
  pause
}

cleanup_candidates() {
  find "$REUNIOES_DIR" -maxdepth 1 -type f -name '*.wav' -mtime +"$KEEP_WAV_DAYS" -print | while read -r wav; do
    base="$(file_base "$wav")"
    [[ -f "$base.md" && -f "$base.opus" ]] && printf '%s\n' "$wav"
  done
}

cleanup_wavs() {
  local days
  if [[ ! "$KEEP_WAV_DAYS" =~ ^[0-9]+$ ]]; then
    warn "KEEP_WAV_DAYS inválido ('$KEEP_WAV_DAYS'); a usar 14."
    KEEP_WAV_DAYS=14
  fi
  days="$(input "Apagar WAV com mais de quantos dias? (número)" "$KEEP_WAV_DAYS")"
  if [[ ! "$days" =~ ^[0-9]+$ ]]; then
    warn "Valor inválido: '$days'. Indica um número de dias, por exemplo: 14."
    pause; return
  fi
  KEEP_WAV_DAYS="$days"
  mapfile -t files < <(cleanup_candidates)
  if (( ${#files[@]} == 0 )); then
    warn "Nenhum WAV elegível. Regra: idade > ${KEEP_WAV_DAYS} dias + MD + OPUS existentes."
    pause; return
  fi
  echo "Elegíveis para apagar:"
  printf '  %s\n' "${files[@]}"
  echo
  confirm "Apagar estes ${#files[@]} WAV? (irreversível)" || return
  local f
  for f in "${files[@]}"; do
    rm -v -- "$f"
  done
  pause
}

record_meeting() {
  local timestamp audio_file monitor mic ffmpeg_pid ffmpeg_status
  local recording_stopped=false

  timestamp=$(date +%Y-%m-%d_%H%M)
  mkdir -p "$REUNIOES_DIR"
  audio_file="$REUNIOES_DIR/reuniao_${timestamp}.wav"

  local mic_gain="${MIC_GAIN:-1.20}"
  local monitor_gain="${MONITOR_GAIN:-0.92}"
  local output_rate="${OUTPUT_RATE:-24000}"
  local mic_filter="${MIC_FILTER:-highpass=f=80,lowpass=f=9000,afftdn=nf=-20,acompressor=threshold=0.09:ratio=3:attack=5:release=90:makeup=3,alimiter=limit=0.92}"

  style "🎙 A gravar reunião"
  echo "Ficheiro: $audio_file"
  echo

  monitor="$(pactl get-default-sink).monitor"
  mic="$(pactl get-default-source)"

  echo "Monitor : $monitor"
  echo "Microfone: $mic"
  echo
  echo "Antes de gravar, confirma:"
  echo "✅ Estás a ouvir a reunião pelo dispositivo correto?"
  echo "✅ O microfone está ligado?"
  echo

  if ( : </dev/tty ) 2>/dev/null; then
    read -rp "Prima Enter para começar a gravar (Ctrl+C para parar/cancelar)..." _ </dev/tty || return
  else
    read -rp "Prima Enter para começar a gravar (Ctrl+C para parar/cancelar)..." _ || return
  fi
  echo

  stop_recording() {
    recording_stopped=true
    echo
    echo "⏹  A parar gravação..."
    [[ -n "${ffmpeg_pid:-}" ]] && kill "$ffmpeg_pid" 2>/dev/null || true
  }

  trap stop_recording INT

  ffmpeg -f pulse -i "$monitor" -f pulse -i "$mic" \
    -filter_complex "[0:a]aformat=channel_layouts=mono,volume=${monitor_gain}[mon];[1:a]aformat=channel_layouts=mono,${mic_filter},volume=${mic_gain}[mic];[mon][mic]amix=inputs=2:duration=longest:normalize=0[mix];[mix]alimiter=limit=0.95[out]" \
    -map "[out]" -ar "$output_rate" -c:a pcm_s16le "$audio_file" 2>/dev/null &
  ffmpeg_pid=$!

  set +e
  wait "$ffmpeg_pid"
  ffmpeg_status=$?
  set -e
  trap - INT

  if [[ $ffmpeg_status -ne 0 && $recording_stopped != true ]]; then
    err "A gravação terminou de forma inesperada."
    return "$ffmpeg_status"
  fi

  echo
  echo "✅ Gravação terminada"
  echo "   WAV: $audio_file"
  echo
  echo "Para transcrever depois pelo TUI:"
  echo "  reunioes transcrever"
  echo
  echo "Comando direto avançado:"
  printf '  PT: WHISPER_MODEL=large-v3 WHISPER_LANGUAGE=pt transcrever-reuniao %q\n' "$audio_file"
  printf '  EN: WHISPER_MODEL=large-v3 WHISPER_LANGUAGE=en transcrever-reuniao %q\n' "$audio_file"
  pause
}

open_folder() {
  if has xdg-open; then xdg-open "$REUNIOES_DIR" >/dev/null 2>&1 & disown || true; fi
  info "$REUNIOES_DIR"
  pause
}

show_help() {
  cat <<'EOF'
Workflow recomendado

1. reunioes → Gravar nova reunião
   - grava diretamente dentro do TUI
   - cria WAV em ~/Sync/Reunioes

2. reunioes → Transcrever áudio pendente
   - usa large-v3 por defeito
   - escolhe pt/en
   - pode criar OPUS no fim
   - mantém WAV sempre

3. Se a transcrição falhar ou ficar parcial
   - usar “Refazer transcrição”
   - a versão antiga é guardada em backup
   - pode correr em tmux/background para sobreviver a quedas da sessão

4. Rever transcrição (.md)
   - usar para resumo Logseq

5. Arquivar WAV para OPUS
   - só arquiva WAV que já têm MD
   - não apaga WAV

6. Limpar WAV antigos
   - só apaga WAV com mais de N dias
   - só se existir MD + OPUS
   - pede confirmação explícita

Variáveis úteis

REUNIOES_DIR=~/Sync/Reunioes
WHISPER_MODEL_DEFAULT=large-v3
CHUNK_SECONDS_DEFAULT=180
OPUS_BITRATE=48k
KEEP_WAV_DAYS=14

Comandos diretos

reunioes gravar
reunioes status
reunioes transcrever
reunioes refazer
reunioes arquivar
reunioes arquivar-tudo
reunioes limpar
reunioes help
EOF
  pause
}

main_menu() {
  while true; do
    clear || true
    style "🎙 Reuniões"
    echo "Pasta: $REUNIOES_DIR"
    echo
    choice="$(choose "Escolhe" \
      "Gravar nova reunião" \
      "Ver estado" \
      "Transcrever áudio pendente" \
      "Refazer transcrição" \
      "Arquivar um WAV para OPUS" \
      "Arquivar todos os WAV elegíveis" \
      "Limpar WAV antigos" \
      "Abrir pasta" \
      "Help" \
      "Sair")"
    case "$choice" in
      "Gravar nova reunião") record_meeting ;;
      "Ver estado") show_status; pause ;;
      "Transcrever áudio pendente") transcribe_pending ;;
      "Refazer transcrição") retranscribe_audio ;;
      "Arquivar um WAV para OPUS") archive_one ;;
      "Arquivar todos os WAV elegíveis") archive_all ;;
      "Limpar WAV antigos") cleanup_wavs ;;
      "Abrir pasta") open_folder ;;
      "Help") show_help ;;
      "Sair"|"") break ;;
    esac
  done
}

cmd="${1:-menu}"
case "$cmd" in
  menu) main_menu ;;
  gravar) record_meeting ;;
  status) show_status ;;
  transcrever) transcribe_pending ;;
  refazer) retranscribe_audio ;;
  refazer-job) shift; retranscribe_job "$@" ;;
  arquivar) archive_one ;;
  arquivar-tudo) archive_all ;;
  limpar) cleanup_wavs ;;
  help|-h|--help) show_help ;;
  *)
    err "Comando desconhecido: $cmd"
    echo "Usa: reunioes help"
    exit 2
    ;;
esac
