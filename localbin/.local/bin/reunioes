#!/bin/bash

set -euo pipefail

REUNIOES_ENV="${REUNIOES_ENV:-$HOME/.config/reunioes/env}"
if [[ -f "$REUNIOES_ENV" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$REUNIOES_ENV"
  set +a
fi

REUNIOES_DIR="${REUNIOES_DIR:-$HOME/Sync/Reunioes}"
TRANSCRICOES_DIR="${TRANSCRICOES_DIR:-$REUNIOES_DIR/transcricoes}"
AUDIO_DIR="${AUDIO_DIR:-$REUNIOES_DIR/audio}"
WAV_DIR="${WAV_DIR:-$AUDIO_DIR/wav}"
LOCAL_WAV_DIR="${LOCAL_WAV_DIR:-$HOME/.local/state/reunioes/wav}"
OPUS_DIR="${OPUS_DIR:-$AUDIO_DIR/opus}"
LOG_DIR="${LOG_DIR:-$REUNIOES_DIR/logs}"
BACKUP_DIR="${BACKUP_DIR:-$REUNIOES_DIR/backups}"
WHISPER_MODEL_DEFAULT="${WHISPER_MODEL_DEFAULT:-large-v3}"
CHUNK_SECONDS_DEFAULT="${CHUNK_SECONDS_DEFAULT:-180}"
TRANSCRIBER_BIN="${TRANSCRIBER_BIN:-$(command -v transcrever-audio 2>/dev/null || printf '%s/.local/bin/transcrever-audio' "$HOME")}"
OPUS_BITRATE="${OPUS_BITRATE:-48k}"
KEEP_WAV_DAYS="${KEEP_WAV_DAYS:-14}"
QC_MIN_DURATION_SECONDS="${QC_MIN_DURATION_SECONDS:-60}"
QC_MAX_DURATION_SECONDS="${QC_MAX_DURATION_SECONDS:-10800}"
QC_SILENCE_NOISE="${QC_SILENCE_NOISE:--45dB}"
QC_SILENCE_MIN_DURATION="${QC_SILENCE_MIN_DURATION:-2}"
QC_MAX_SILENCE_PERCENT="${QC_MAX_SILENCE_PERCENT:-60}"
QC_MIN_MAX_VOLUME_DB="${QC_MIN_MAX_VOLUME_DB:--35}"
ARCHIVE_INDEX="${ARCHIVE_INDEX:-$REUNIOES_DIR/.arquivo-audio.tsv}"
OBSIDIAN_PGR_DIR="${OBSIDIAN_PGR_DIR:-$HOME/Sync/Obsidian/PGR}"
OBSIDIAN_PERSONAL_DIR="${OBSIDIAN_PERSONAL_DIR:-$HOME/Sync/Obsidian/Personal}"
OBSIDIAN_DAILY_DIR="${OBSIDIAN_DAILY_DIR:-$OBSIDIAN_PGR_DIR/daily}"
TODOIST_ADD_BIN="${TODOIST_ADD_BIN:-todoist-add}"
TODOIST_PROJECTS_BIN="${TODOIST_PROJECTS_BIN:-todoist-projects}"
TODOIST_TUI_BIN="${TODOIST_TUI_BIN:-todoist-tui}"
TODOIST_PROJECT_DEFAULT="${TODOIST_PROJECT_DEFAULT:-Work}"
REUNIOES_AI_CMD="${REUNIOES_AI_CMD:-pi}"
REUNIOES_AI_PROVIDER="${REUNIOES_AI_PROVIDER:-}"
REUNIOES_AI_MODEL="${REUNIOES_AI_MODEL:-}"
REUNIOES_AI_THINKING="${REUNIOES_AI_THINKING:-minimal}"
REUNIOES_AI_LANG="${REUNIOES_AI_LANG:-português de Portugal}"

has() { command -v "$1" >/dev/null 2>&1; }

reunioes_self() {
  if [[ -n "${REUNIOES_COMMAND:-}" && -x "$REUNIOES_COMMAND" ]]; then
    printf '%s' "$REUNIOES_COMMAND"
  elif [[ "$0" == */* && -x "$0" ]]; then
    printf '%s' "$0"
  else
    command -v reunioes 2>/dev/null || printf '%s' "$0"
  fi
}

load_todoist_env() {
  if [[ -z "${TODOIST_API_TOKEN:-}" && -f "$HOME/.config/secrets/env" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$HOME/.config/secrets/env"
    set +a
  fi
}

use_gum() { has gum && [[ -t 0 && -t 1 ]] && ( : </dev/tty ) 2>/dev/null; }
use_fzf() { has fzf && ( : </dev/tty ) 2>/dev/null; }

print_tty() {
  if ( : >/dev/tty ) 2>/dev/null; then printf '%s\n' "$*" >/dev/tty
  else printf '%s\n' "$*" >&2; fi
}
info_tty() { print_tty "ℹ️  $*"; }
warn_tty() { print_tty "⚠️  $*"; }

# Caminho curto para menus/preview.
display_path() {
  local path="$1"
  if [[ "$path" == "$OBSIDIAN_PGR_DIR/"* ]]; then printf '%s' "${path#$OBSIDIAN_PGR_DIR/}"
  elif [[ "$path" == "$OBSIDIAN_PERSONAL_DIR/"* ]]; then printf 'Personal/%s' "${path#$OBSIDIAN_PERSONAL_DIR/}"
  elif [[ "$path" == "$REUNIOES_DIR/"* ]]; then printf '%s' "${path#$REUNIOES_DIR/}"
  elif [[ "$path" == "$HOME/"* ]]; then printf '~/%s' "${path#$HOME/}"
  else printf '%s' "$path"; fi
}

# Preview leve para fzf e confirmação manual: mostra caminho + primeiro bloco útil.
markdown_preview() {
  local path="$1"
  printf '📄 %s\n' "$path"
  if [[ -d "$path" ]]; then
    echo
    echo "Notas recentes nesta pasta:"
    find "$path" -maxdepth 1 -type f -name '*.md' -printf '%TY-%Tm-%Td %TH:%TM  %f\n' 2>/dev/null \
      | sort -r | head -30
    return 0
  fi
  if [[ ! -f "$path" ]]; then echo "Não existe."; return 0; fi
  stat -c 'Modificado: %y' "$path" 2>/dev/null | cut -d. -f1
  printf 'Tamanho: %s bytes\n\n' "$(stat -c '%s' "$path" 2>/dev/null || printf '0')"
  awk '
    BEGIN { fm=0; lines=0; started=0; blanks_after_start=0; shown_heading=0 }
    NR == 1 && $0 == "---" { fm=1; next }
    fm && $0 == "---" { fm=0; next }
    fm { next }
    /^[[:space:]]*$/ { if (started) { blanks_after_start++; if (blanks_after_start >= 1 && lines >= 4) exit } ; next }
    /^```/ { next }
    {
      line=$0; sub(/\r$/, "", line)
      if (line ~ /^#/ && shown_heading) next
      if (line ~ /^#/) shown_heading=1
      if (length(line) > 180) line=substr(line, 1, 177) "..."
      print line
      lines++; started=1
      if (lines >= 14) exit
    }
    END { if (lines == 0) print "(sem texto útil nos primeiros parágrafos)" }
  ' "$path" 2>/dev/null
}

show_markdown_preview_tty() {
  local path="$1"
  if ( : >/dev/tty ) 2>/dev/null; then markdown_preview "$path" >/dev/tty
  else markdown_preview "$path" >&2; fi
}

clean_manual_path() {
  local path="$*" first last
  path="${path//$'\r'/}"
  path="${path#"${path%%[![:space:]]*}"}"
  path="${path%"${path##*[![:space:]]}"}"
  [[ -z "$path" ]] && return 0

  if [[ "$path" == \[\[*\]\] ]]; then
    path="${path#\[\[}"; path="${path%\]\]}"; path="${path%%|*}"; path="${path%%#*}"
  fi
  [[ "$path" == file://* ]] && path="${path#file://}"

  if (( ${#path} >= 2 )); then
    first="${path:0:1}"; last="${path: -1}"
    if [[ ( "$first" == "'" && "$last" == "'" ) || ( "$first" == '"' && "$last" == '"' ) || ( "$first" == '`' && "$last" == '`' ) ]]; then
      path="${path:1:${#path}-2}"
    fi
  fi

  path="${path//\\ / }"
  path="${path//\\(/(}"; path="${path//\\)/)}"
  path="${path//\\[/[}"; path="${path//\\]/]}"
  case "$path" in
    '~') path="$HOME" ;;
    '~/'*) path="$HOME/${path#\~/}" ;;
  esac
  printf '%s' "$path"
}

append_unique_candidate() {
  local -n _candidates="$1"
  local candidate="$2" existing
  [[ -n "$candidate" ]] || return 0
  for existing in "${_candidates[@]}"; do [[ "$existing" == "$candidate" ]] && return 0; done
  _candidates+=("$candidate")
}

append_markdown_candidate() {
  local array_name="$1" candidate="$2"
  append_unique_candidate "$array_name" "$candidate"
  [[ "$candidate" == *.md ]] || append_unique_candidate "$array_name" "$candidate.md"
}

resolve_markdown_manual_paths() {
  local manual="$1" raw root candidate
  shift || true
  local roots=("$@") candidates=()
  raw="$(clean_manual_path "$manual")"
  [[ -n "$raw" ]] || return 1

  if [[ "$raw" == /* ]]; then
    append_markdown_candidate candidates "$raw"
  else
    append_markdown_candidate candidates "$PWD/$raw"
    for root in "${roots[@]}"; do [[ -d "$root" ]] && append_markdown_candidate candidates "$root/$raw"; done
  fi

  {
    for candidate in "${candidates[@]}"; do
      [[ -f "$candidate" ]] && realpath -m -- "$candidate" 2>/dev/null
    done
    true
  } | awk '!seen[$0]++'
}

# Cabeçalho em caixa. Cores herdadas do tema Omarchy via vars GUM_* / BORDER_FOREGROUND.
style() {
  if use_gum; then
    gum style --border rounded --padding "0 2" --margin "0 0 1 0" --bold "$@"
  else
    printf '== %s ==\n' "$*"
  fi
}
info() { printf 'ℹ️  %s\n' "$*"; }
warn() { printf '⚠️  %s\n' "$*"; }
err() { printf '❌ %s\n' "$*" >&2; }

pause() {
  echo
  if ( : </dev/tty ) 2>/dev/null; then read -rp "Enter para continuar..." _ </dev/tty || true
  elif [[ -t 0 ]]; then read -rp "Enter para continuar..." _ || true; fi
}

confirm() {
  local prompt="$1" answer
  if use_gum; then gum confirm "$prompt" </dev/tty >/dev/tty
  else
    if ( : </dev/tty ) 2>/dev/null; then read -rp "$prompt [y/N] " answer </dev/tty
    else read -rp "$prompt [y/N] " answer; fi
    [[ "${answer,,}" == "y" || "${answer,,}" == "yes" || "${answer,,}" == "s" || "${answer,,}" == "sim" ]]
  fi
}

choose() {
  local header="$1"; shift
  if use_gum; then gum choose --header "$header" --height 15 "$@" </dev/tty
  elif use_fzf; then
    printf '%s\n' "$@" | fzf --height 40% --layout=reverse --border --prompt "# " --header "$header"
  else
    local opt
    echo "$header" >/dev/tty
    select opt in "$@"; do [[ -n "${opt:-}" ]] && { printf '%s\n' "$opt"; return 0; }; done </dev/tty
  fi
}

input() {
  local prompt="$1" default="${2:-}" value
  if use_gum; then gum input --prompt "$prompt " --value "$default" </dev/tty
  else
    if ( : </dev/tty ) 2>/dev/null; then read -rp "$prompt [$default] " value </dev/tty
    else read -rp "$prompt [$default] " value; fi
    printf '%s\n' "${value:-$default}"
  fi
}

textarea() {
  local prompt="$1" line value=""
  if use_gum; then
    gum write --header "$prompt" --placeholder "Opcional. Escreve contexto, nomes, foco do resumo, decisões/ações a procurar..." --height 8 </dev/tty
  else
    echo "$prompt" >/dev/tty
    echo "Opcional. Escreve várias linhas; termina com uma linha só com '.'" >/dev/tty
    while IFS= read -r line </dev/tty; do
      [[ "$line" == "." ]] && break
      value+="${line}"$'\n'
    done
    printf '%s' "$value"
  fi
}

copy_to_clipboard() {
  local file="$1"
  [[ -f "$file" ]] || return 1
  if has wl-copy; then wl-copy < "$file"; return 0; fi
  if has xclip; then xclip -selection clipboard < "$file"; return 0; fi
  if has xsel; then xsel --clipboard --input < "$file"; return 0; fi
  if has pbcopy; then pbcopy < "$file"; return 0; fi
  return 1
}

init_project_dirs() {
  mkdir -p "$TRANSCRICOES_DIR" "$WAV_DIR" "$LOCAL_WAV_DIR" "$OPUS_DIR" "$LOG_DIR" "$BACKUP_DIR"
  ensure_archive_index
  ensure_syncthing_ignore
}

ensure_syncthing_ignore() {
  local ignore_file="$REUNIOES_DIR/.stignore"
  touch "$ignore_file"
  grep -qxF '.incoming-*' "$ignore_file" || printf '%s\n' '.incoming-*' >> "$ignore_file"
  grep -qxF '*.part' "$ignore_file" || printf '%s\n' '*.part' >> "$ignore_file"
  grep -qxF '*.tmp' "$ignore_file" || printf '%s\n' '*.tmp' >> "$ignore_file"
}

file_base() { local f="$1"; printf '%s' "${f%.*}"; }
file_size() { stat -c '%s' "$1" 2>/dev/null || printf '0'; }
human_size() { if has numfmt; then numfmt --to=iec --suffix=B "$1"; else printf '%sB' "$1"; fi; }
key_from_path() { basename "$(file_base "$1")"; }
md_for_key() { printf '%s/%s.md' "$TRANSCRICOES_DIR" "$1"; }
wav_for_key() { printf '%s/%s.wav' "$WAV_DIR" "$1"; }
opus_for_key() { printf '%s/%s.opus' "$OPUS_DIR" "$1"; }
local_wav_for_key() { printf '%s/%s.wav' "$LOCAL_WAV_DIR" "$1"; }

audio_quality_check() {
  local audio="$1" report="$2" duration duration_h vol_log silence_log mean_volume max_volume silence_total silence_pct warnings=0
  mkdir -p "$(dirname "$report")"
  vol_log="$(mktemp)"
  silence_log="$(mktemp)"

  duration="$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$audio" 2>/dev/null || printf '0')"
  duration_h="$(awk -v d="$duration" 'BEGIN { h=int(d/3600); m=int((d%3600)/60); s=int(d%60); printf "%02d:%02d:%02d", h, m, s }')"

  ffmpeg -hide_banner -nostats -i "$audio" -af volumedetect -f null - > /dev/null 2>"$vol_log" || true
  mean_volume="$(awk -F': ' '/mean_volume:/ {print $2}' "$vol_log" | awk '{print $1}' | tail -1)"
  max_volume="$(awk -F': ' '/max_volume:/ {print $2}' "$vol_log" | awk '{print $1}' | tail -1)"
  mean_volume="${mean_volume:-n/a}"
  max_volume="${max_volume:-n/a}"

  ffmpeg -hide_banner -nostats -i "$audio" -af "silencedetect=noise=${QC_SILENCE_NOISE}:d=${QC_SILENCE_MIN_DURATION}" -f null - > /dev/null 2>"$silence_log" || true
  silence_total="$(awk '/silence_duration:/ {sum += $NF} END {printf "%.3f", sum + 0}' "$silence_log")"
  silence_pct="$(awk -v s="$silence_total" -v d="$duration" 'BEGIN { if (d > 0) printf "%.1f", (s / d) * 100; else printf "0.0" }')"

  {
    echo "# Qualidade da gravação"
    echo "Data: $(date --iso-8601=seconds)"
    echo "Ficheiro: $audio"
    echo "Duração: $duration_h (${duration}s)"
    echo "Tamanho: $(human_size "$(file_size "$audio")")"
    echo "Volume médio: ${mean_volume} dB"
    echo "Volume máximo: ${max_volume} dB"
    echo "Silêncio detectado: ${silence_total}s (${silence_pct}%)"
    echo "Parâmetros: silêncio=${QC_SILENCE_NOISE}, janela=${QC_SILENCE_MIN_DURATION}s, máx silêncio=${QC_MAX_SILENCE_PERCENT}%, duração máx=${QC_MAX_DURATION_SECONDS}s"
    echo
    echo "## Avisos"
  } > "$report"

  if awk -v d="$duration" -v min="$QC_MIN_DURATION_SECONDS" 'BEGIN { exit !(d < min) }'; then
    echo "- Duração muito curta (< ${QC_MIN_DURATION_SECONDS}s). Pode ser gravação acidental/incompleta." | tee -a "$report"
    warnings=$((warnings + 1))
  fi
  if awk -v d="$duration" -v max="$QC_MAX_DURATION_SECONDS" 'BEGIN { exit !(d > max) }'; then
    echo "- Duração muito longa (> ${QC_MAX_DURATION_SECONDS}s). Podes ter esquecido a gravação ligada." | tee -a "$report"
    warnings=$((warnings + 1))
  fi
  if [[ "$max_volume" != "n/a" ]] && awk -v v="$max_volume" -v min="$QC_MIN_MAX_VOLUME_DB" 'BEGIN { exit !(v < min) }'; then
    echo "- Volume máximo muito baixo (${max_volume} dB). Pode haver silêncio ou captação errada." | tee -a "$report"
    warnings=$((warnings + 1))
  fi
  if awk -v p="$silence_pct" -v max="$QC_MAX_SILENCE_PERCENT" 'BEGIN { exit !(p > max) }'; then
    echo "- Percentagem de silêncio elevada (${silence_pct}%). Pode haver gravação vazia ou demasiado tempo morto." | tee -a "$report"
    warnings=$((warnings + 1))
  fi
  if (( warnings == 0 )); then
    echo "- Sem avisos automáticos." >> "$report"
  fi

  rm -f -- "$vol_log" "$silence_log"
  cat "$report"
  return "$warnings"
}

publish_wav() {
  local src="$1" dst="$2" dst_dir tmp src_dev dst_dev src_size tmp_size
  dst_dir="$(dirname "$dst")"
  mkdir -p "$dst_dir"
  if [[ -e "$dst" ]]; then
    err "Destino já existe, não vou sobrescrever: $dst"
    return 1
  fi

  src_dev="$(stat -c '%d' "$src")"
  dst_dev="$(stat -c '%d' "$dst_dir")"
  if [[ "$src_dev" == "$dst_dev" ]]; then
    mv -- "$src" "$dst"
    return 0
  fi

  # Fallback para filesystems diferentes: copiar para nome ignorado pelo Syncthing e só depois renomear.
  tmp="$dst_dir/.incoming-$(basename "$dst")"
  rm -f -- "$tmp"
  cp --reflink=auto --preserve=timestamps -- "$src" "$tmp"
  src_size="$(file_size "$src")"
  tmp_size="$(file_size "$tmp")"
  if [[ "$src_size" != "$tmp_size" ]]; then
    rm -f -- "$tmp"
    err "Cópia incompleta: origem=$src_size destino=$tmp_size"
    return 1
  fi
  mv -- "$tmp" "$dst"
  rm -f -- "$src"
}

ensure_archive_index() {
  mkdir -p "$(dirname "$ARCHIVE_INDEX")"
  if [[ ! -f "$ARCHIVE_INDEX" ]]; then
    printf 'base\twav_bytes\topus_bytes\tsaved_bytes\topus_created_at\twav_removed_at\n' > "$ARCHIVE_INDEX"
  fi
}

archive_saved_bytes() {
  local base="$1"
  [[ -f "$ARCHIVE_INDEX" ]] || return 1
  awk -F '\t' -v base="$base" 'NR > 1 && $1 == base && $4 ~ /^[0-9]+$/ { saved = $4 } END { if (saved != "") print saved }' "$ARCHIVE_INDEX"
}

archive_upsert_unlocked() {
  local base="$1" wav_bytes="$2" opus_bytes="$3" saved_bytes="$4" opus_created_at="$5" wav_removed_at="${6:-}" tmp
  tmp="$(mktemp)"
  awk -F '\t' -v OFS='\t' \
    -v base="$base" -v wav="$wav_bytes" -v opus="$opus_bytes" -v saved="$saved_bytes" \
    -v created="$opus_created_at" -v removed="$wav_removed_at" '
      NR == 1 { print; next }
      $1 == base {
        if (removed == "" && $6 != "") removed = $6
        print base, wav, opus, saved, created, removed
        found = 1
        next
      }
      { print }
      END { if (!found) print base, wav, opus, saved, created, removed }
    ' "$ARCHIVE_INDEX" > "$tmp"
  mv -- "$tmp" "$ARCHIVE_INDEX"
}

archive_with_lock() {
  ensure_archive_index
  if command -v flock >/dev/null 2>&1; then
    (
      flock -x 9
      "$@"
    ) 9>"$ARCHIVE_INDEX.lock"
  else
    "$@"
  fi
}

archive_upsert() {
  archive_with_lock archive_upsert_unlocked "$@"
}

archive_record_opus() {
  local wav="$1" opus="$2" base wav_bytes opus_bytes saved_bytes
  [[ -s "$wav" && -s "$opus" ]] || return 0
  base="$(key_from_path "$wav")"
  wav_bytes="$(file_size "$wav")"
  opus_bytes="$(file_size "$opus")"
  saved_bytes=0
  if (( wav_bytes > opus_bytes )); then saved_bytes=$((wav_bytes - opus_bytes)); fi
  archive_upsert "$base" "$wav_bytes" "$opus_bytes" "$saved_bytes" "$(date --iso-8601=seconds)" ""
  info "Poupança registada: $(human_size "$saved_bytes") em $ARCHIVE_INDEX"
}

archive_mark_removed_unlocked() {
  local base="$1" removed="$2" tmp
  tmp="$(mktemp)"
  awk -F '\t' -v OFS='\t' -v base="$base" -v removed="$removed" '
    NR == 1 { print; next }
    $1 == base { $6 = removed; found = 1 }
    { print }
    END { if (!found) print base, "", "", "", "", removed }
  ' "$ARCHIVE_INDEX" > "$tmp"
  mv -- "$tmp" "$ARCHIVE_INDEX"
}

archive_mark_removed() {
  local wav="$1" base opus removed
  base="$(key_from_path "$wav")"
  opus="$(opus_for_key "$base")"
  if [[ -f "$wav" && -f "$opus" ]]; then archive_record_opus "$wav" "$opus"; fi
  removed="$(date --iso-8601=seconds)"
  archive_with_lock archive_mark_removed_unlocked "$base" "$removed"
}

meeting_keys() {
  init_project_dirs
  shopt -s nullglob
  local f key
  for f in "$TRANSCRICOES_DIR"/reuniao_*.md "$WAV_DIR"/reuniao_*.wav "$LOCAL_WAV_DIR"/reuniao_*.wav "$OPUS_DIR"/reuniao_*.opus; do
    [[ -f "$f" ]] || continue
    case "${f##*/}" in *.bak-*.md|*.partial.md|*.retry*.md) continue;; esac
    key="$(key_from_path "$f")"
    printf '%s\n' "$key"
  done | sort -u
}

meeting_rows() {
  local key wav md opus wav_s md_s opus_s saved size_wav size_opus date hour
  printf 'Data\tHora\tWAV\tMD\tOPUS\tPoupança\tBase\n'
  while IFS= read -r key; do
    wav="$(wav_for_key "$key")"; md="$(md_for_key "$key")"; opus="$(opus_for_key "$key")"
    if [[ -e "$wav" ]]; then
      wav_s="✅"
    elif [[ -e "$(local_wav_for_key "$key")" ]]; then
      wav_s="local"
    else
      wav_s="—"
    fi
    [[ -e "$md" ]] && md_s="✅" || md_s="—"
    [[ -e "$opus" ]] && opus_s="✅" || opus_s="—"
    saved="—"
    if [[ -e "$wav" && -e "$opus" ]]; then
      size_wav=$(file_size "$wav"); size_opus=$(file_size "$opus")
      if (( size_wav > size_opus )); then saved="$(human_size $((size_wav - size_opus)))"; fi
    elif [[ -e "$opus" ]]; then
      size_opus=$(archive_saved_bytes "$key" || true)
      if [[ "${size_opus:-}" =~ ^[0-9]+$ && "$size_opus" -gt 0 ]]; then saved="$(human_size "$size_opus")"; fi
    fi
    if [[ "$key" =~ ^reuniao_([0-9]{4}-[0-9]{2}-[0-9]{2})_([0-9]{2})([0-9]{2})$ ]]; then
      date="${BASH_REMATCH[1]}"; hour="${BASH_REMATCH[2]}:${BASH_REMATCH[3]}"
    else
      date="?"; hour="?"
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$date" "$hour" "$wav_s" "$md_s" "$opus_s" "$saved" "$key"
  done < <(meeting_keys)
}

show_status() {
  init_project_dirs
  style "🎙 Reuniões — estado"
  {
    printf 'Projeto\t%s\n' "$REUNIOES_DIR"
    printf 'Transcrições\t%s\n' "$TRANSCRICOES_DIR"
    printf 'WAV publicado\t%s\n' "$WAV_DIR"
    printf 'WAV local/pendente\t%s\n' "$LOCAL_WAV_DIR"
    printf 'OPUS\t%s\n' "$OPUS_DIR"
  } | column -t -s $'\t'
  echo
  if use_gum; then
    meeting_rows | gum table --separator $'\t' --height 25 \
      --widths 12,6,6,4,6,12,28 --print
  else
    meeting_rows | column -t -s $'\t'
  fi
}

pending_transcriptions() {
  init_project_dirs
  shopt -s nullglob
  local audio key priority
  # Ordenar por base ISO e preferir WAV quando existem WAV+OPUS sem transcrição.
  for audio in "$WAV_DIR"/*.wav "$OPUS_DIR"/*.opus; do
    [[ -f "$audio" ]] || continue
    key="$(key_from_path "$audio")"
    [[ -f "$(md_for_key "$key")" ]] && continue
    [[ "$audio" == *.wav ]] && priority=0 || priority=1
    printf '%s\t%s\t%s\n' "$key" "$priority" "$audio"
  done | sort -t $'\t' -k1,1 -k2,2n | awk -F '\t' '!seen[$1]++ { print $3 }'
}

choose_audio_file() {
  local prompt="$1"
  mapfile -t files < <(pending_transcriptions)
  if (( ${#files[@]} == 0 )); then warn "Não há áudio pendente de transcrição."; return 1; fi
  choose "$prompt" "${files[@]}"
}

transcribe_pending() {
  local audio key lang archive model chunks output hints
  audio="$(choose_audio_file "Áudio para transcrever")" || { pause; return; }
  key="$(key_from_path "$audio")"
  output="$(md_for_key "$key")"
  lang="$(choose "Língua" "pt" "en" "auto")"; [[ "$lang" == "auto" ]] && lang=""
  model="$(input "Modelo" "$WHISPER_MODEL_DEFAULT")"
  chunks="$(input "Blocos segundos" "$CHUNK_SECONDS_DEFAULT")"
  archive="0"
  if [[ "$audio" == *.wav ]] && confirm "Criar OPUS no fim da transcrição? (mantém WAV)"; then archive="1"; fi
  echo; info "A transcrever: $audio -> $output"
  if [[ -n "$lang" ]]; then
    TRANSCRICOES_DIR="$TRANSCRICOES_DIR" OPUS_DIR="$OPUS_DIR" ARCHIVE_INDEX="$ARCHIVE_INDEX" WHISPER_MODEL="$model" WHISPER_LANGUAGE="$lang" CHUNK_SECONDS="$chunks" ARCHIVE_OPUS="$archive" "$TRANSCRIBER_BIN" "$audio" "$output"
  else
    TRANSCRICOES_DIR="$TRANSCRICOES_DIR" OPUS_DIR="$OPUS_DIR" ARCHIVE_INDEX="$ARCHIVE_INDEX" WHISPER_MODEL="$model" WHISPER_LANGUAGE="" CHUNK_SECONDS="$chunks" ARCHIVE_OPUS="$archive" "$TRANSCRIBER_BIN" "$audio" "$output"
  fi
  if [[ -f "$output" ]] && confirm "Gerar rascunho Obsidian com IA agora?"; then
    hints="$(textarea "Indicações opcionais para o agente IA desta reunião")"
    draft_obsidian_note_ai "$output" "" "$hints"
  fi
  pause
}

all_transcription_files() {
  init_project_dirs
  find "$TRANSCRICOES_DIR" -maxdepth 1 -type f -name 'reuniao_*.md' \
    ! -name '*.bak-*.md' ! -name '*.partial.md' ! -name '*.retry*.md' \
    -printf '%T@\t%p\n' 2>/dev/null | sort -nr | cut -f2-
}

transcription_files_search() {
  local query="$1" limit="${2:-40}" path haystack count=0
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    haystack="$(display_path "$path")"
    if [[ -z "$query" || "${haystack,,}" == *"${query,,}"* ]] || grep -qiF -- "$query" "$path" 2>/dev/null; then
      printf '%s\n' "$path"
      count=$((count + 1))
      (( count >= limit )) && break
    fi
  done < <(all_transcription_files)
}

resolve_transcription_manual_paths() {
  local manual="$1" raw path base target
  raw="$(clean_manual_path "$manual")"
  [[ -n "$raw" ]] || return 1
  {
    resolve_markdown_manual_paths "$raw" "$TRANSCRICOES_DIR" "$REUNIOES_DIR"
    if [[ "$raw" != */* ]]; then
      target="$(basename "${raw%.md}")"
      while IFS= read -r path; do
        base="$(basename "${path%.md}")"
        [[ "${base,,}" == "${target,,}" || "${base,,}" == *"${target,,}"* ]] && printf '%s\n' "$path"
      done < <(all_transcription_files)
    fi
    true
  } | awk '!seen[$0]++'
}

choose_transcription_file() {
  local prompt="$1" choice query manual
  local files=() all_files=()
  mapfile -t all_files < <(all_transcription_files)
  if (( ${#all_files[@]} == 0 )); then warn_tty "Não há transcrições em $TRANSCRICOES_DIR."; return 1; fi

  while true; do
    choice="$(choose "$prompt — como escolher?" \
      "Últimas 15 transcrições" "Pesquisar por data/texto" "Introduzir caminho manual" "Cancelar")" || return 1
    case "$choice" in
      "Últimas 15 transcrições")
        files=("${all_files[@]:0:15}")
        choose_path_from_files "$prompt — últimas 15" "${files[@]}" && return 0
        ;;
      "Pesquisar por data/texto")
        query="$(input "Texto/data a procurar na transcrição" "")" || return 1
        mapfile -t files < <(transcription_files_search "$query" 40)
        if (( ${#files[@]} == 0 )); then warn_tty "Sem transcrições encontradas para: $query"; continue; fi
        choose_path_from_files "$prompt — pesquisa: $query" "${files[@]}" && return 0
        ;;
      "Introduzir caminho manual")
        manual="$(input "Caminho ou nome da transcrição" "")" || return 1
        [[ -z "$manual" ]] && continue
        mapfile -t files < <(resolve_transcription_manual_paths "$manual")
        if (( ${#files[@]} == 0 )); then warn_tty "Transcrição não existe: $manual"; continue; fi
        choose_path_from_files "$prompt — caminho manual" "${files[@]}" && return 0
        ;;
      "Cancelar"|"") return 1 ;;
    esac
  done
}

audio_for_key() {
  local key="$1" opus wav
  opus="$(opus_for_key "$key")"
  wav="$(wav_for_key "$key")"
  if [[ -f "$opus" ]]; then printf '%s' "$opus"; elif [[ -f "$wav" ]]; then printf '%s' "$wav"; fi
}

ai_cmd_base() {
  local -n _arr="$1"
  _arr=("$REUNIOES_AI_CMD" -p --no-tools --no-context-files --no-session --no-extensions --no-skills --no-prompt-templates)
  [[ -n "$REUNIOES_AI_PROVIDER" ]] && _arr+=(--provider "$REUNIOES_AI_PROVIDER")
  [[ -n "$REUNIOES_AI_MODEL" ]] && _arr+=(--model "$REUNIOES_AI_MODEL")
  [[ -n "$REUNIOES_AI_THINKING" ]] && _arr+=(--thinking "$REUNIOES_AI_THINKING")
}

run_ai_obsidian_draft() {
  local md="$1" output="$2" hints="${3:-}" key audio sys prompt rc extra_hints=""
  local ai_cmd=()
  [[ -f "$md" ]] || { err "Transcrição não existe: $md"; return 1; }
  has "$REUNIOES_AI_CMD" || { err "Comando de IA não encontrado: $REUNIOES_AI_CMD"; return 1; }
  mkdir -p "$(dirname "$output")"
  key="$(key_from_path "$md")"
  audio="$(audio_for_key "$key")"
  sys="És assistente de reuniões técnicas da PGR. Transformas transcrições cruas com timestamps e erros de reconhecimento de fala numa nota Obsidian limpa, em ${REUNIOES_AI_LANG}. O sistema ativo é Obsidian + Todoist. Logseq está congelado. NUNCA inventas factos. Devolves SÓ Markdown final, sem preâmbulo."
  if [[ -n "$hints" ]]; then
    extra_hints="$(cat <<EOF

Indicações do Dias para esta nota (prioritárias, mas sem inventar factos):
${hints}
EOF
)"
  fi
  prompt="$(cat <<EOF
Cria uma nota Obsidian PGR a partir da transcrição anexada.

Fonte:
- Transcrição: ${md}
- Áudio: ${audio:-desconhecido}${extra_hints}

Formato recomendado para NOTA GERADA (os templates continuam mínimos):
---
tipo: reuniao
data: "<data YYYY-MM-DD inferida do nome do ficheiro>"
projeto: "<projeto inferido ou vazio>"
estado: sintetizada
fonte_transcricao: "${md}"
audio: "${audio}"
tags: [reuniao]
---

# <título>

> [!summary] Resumo
> - 4 a 8 bullets densos com o essencial.

## Objetivo
- Para que serviu a reunião.

## Pontos principais
- Agrupa por tema, com subtítulos só quando ajudar.

> [!important] Decisões / orientações
> - Só decisões suportadas pela transcrição.

> [!todo] Ações Todoist
> - Ações concretas, começando por verbo. Se não houver ações claras, escreve "Sem ações claras na transcrição.".

> [!question] Follow-ups / dúvidas
> - Pontos a confirmar.

## Fontes
- Transcrição: \`${md}\`
- Áudio: \`${audio}\`

## Palavras-chave
- 

Regras:
- Não mencionar Logseq nem TickTick.
- Não deixar placeholders vazios se houver informação.
- Corrige termos técnicos óbvios, mas marca incertezas com "provável".
- A nota gerada pode e deve ser bonita: callouts, resumo, subtítulos e agregação do importante.
- Não exagerar em frontmatter; a complexidade deve estar no conteúdo, não no template.
- Mantém screenshots/embeds fora se não existirem na transcrição.
EOF
)"
  ai_cmd_base ai_cmd
  info "A gerar rascunho Obsidian com IA: $key"
  set +e
  "${ai_cmd[@]}" --system-prompt "$sys" "@$md" "$prompt" > "$output.tmp" 2> "$output.err"
  rc=$?
  set -e
  if [[ -s "$output.tmp" ]]; then
    if (( rc != 0 )); then warn "IA saiu com código $rc, mas devolveu conteúdo; vou guardar."; fi
    mv -- "$output.tmp" "$output"
    rm -f -- "$output.err"
    return 0
  fi
  err "A IA não devolveu conteúdo. Log: $output.err"
  rm -f -- "$output.tmp"
  return 1
}

obsidian_meeting_roots() {
  # Estrutura atual do vault PGR (2026): projetos/<projeto>/reunioes e reunioes/.
  # Mantém compatibilidade com a estrutura antiga 01_Projetos/02_Reuniões.
  [[ -d "$OBSIDIAN_PGR_DIR/projetos" ]] && printf '%s\n' "$OBSIDIAN_PGR_DIR/projetos"
  [[ -d "$OBSIDIAN_PGR_DIR/reunioes" ]] && printf '%s\n' "$OBSIDIAN_PGR_DIR/reunioes"
  [[ -d "$OBSIDIAN_PGR_DIR/reuniões" ]] && printf '%s\n' "$OBSIDIAN_PGR_DIR/reuniões"
  [[ -d "$OBSIDIAN_PGR_DIR/01_Projetos" ]] && printf '%s\n' "$OBSIDIAN_PGR_DIR/01_Projetos"
  [[ -d "$OBSIDIAN_PGR_DIR/02_Reuniões" ]] && printf '%s\n' "$OBSIDIAN_PGR_DIR/02_Reuniões"
  return 0
}

obsidian_meeting_note_records() {
  mapfile -t roots < <(obsidian_meeting_roots)
  (( ${#roots[@]} > 0 )) || return 0
  find "${roots[@]}" -type f -name '*.md' -printf '%T@\t%p\n' 2>/dev/null \
    | awk -F '\t' '($2 ~ /\/([Rr]eunioes|[Rr]euniões)\// || $2 ~ /\/02_Reuniões\// || $2 ~ /\/02_reuniões\//) && $2 !~ /\/index\.md$/ { print }' \
    | sort -nr
}

obsidian_meeting_notes() {
  local limit="${1:-30}"
  obsidian_meeting_note_records | head -n "$limit" | cut -f2-
}

date_from_path() {
  local path="$1" base
  base="$(basename "$path")"
  if [[ "$base" =~ ([0-9]{4}-[0-9]{2}-[0-9]{2}) ]]; then printf '%s' "${BASH_REMATCH[1]}"; fi
}

obsidian_meeting_notes_for_date() {
  local day="$1" limit="${2:-30}"
  [[ -n "$day" ]] || return 0
  obsidian_meeting_note_records | awk -F '\t' -v day="$day" 'index($2, day) > 0 { print }' | head -n "$limit" | cut -f2-
}

obsidian_meeting_notes_search() {
  local query="$1" limit="${2:-40}" ts path count=0
  if [[ -z "$query" ]]; then obsidian_meeting_notes "$limit"; return; fi
  while IFS=$'\t' read -r ts path; do
    [[ -n "$path" ]] || continue
    if [[ "${path,,}" == *"${query,,}"* ]] || grep -qiF -- "$query" "$path" 2>/dev/null; then
      printf '%s\n' "$path"
      count=$((count + 1))
      (( count >= limit )) && break
    fi
  done < <(obsidian_meeting_note_records)
}

obsidian_meeting_dirs() {
  {
    [[ -d "$OBSIDIAN_PGR_DIR/reunioes" ]] && printf '%s\n' "$OBSIDIAN_PGR_DIR/reunioes"
    [[ -d "$OBSIDIAN_PGR_DIR/reuniões" ]] && printf '%s\n' "$OBSIDIAN_PGR_DIR/reuniões"
    [[ -d "$OBSIDIAN_PGR_DIR/02_Reuniões" ]] && printf '%s\n' "$OBSIDIAN_PGR_DIR/02_Reuniões"
    for root in "$OBSIDIAN_PGR_DIR/projetos" "$OBSIDIAN_PGR_DIR/01_Projetos"; do
      [[ -d "$root" ]] && find "$root" -type d \( -iname 'reunioes' -o -iname 'reuniões' \) 2>/dev/null
    done
    true
  } | sort -u
}

obsidian_meeting_notes_in_dir() {
  local dir="$1" limit="${2:-30}"
  [[ -d "$dir" ]] || return 0
  find "$dir" -maxdepth 1 -type f -name '*.md' -printf '%T@\t%p\n' 2>/dev/null | sort -nr | head -n "$limit" | cut -f2-
}

choose_path_from_files() {
  local header="$1" choice rel i selected
  shift
  local files=("$@") displays=() rows=()
  (( ${#files[@]} > 0 )) || return 1
  for i in "${!files[@]}"; do
    rel="$(display_path "${files[$i]}")"
    displays+=("$rel")
    rows+=("$rel"$'\t'"${files[$i]}")
  done

  if use_fzf; then
    export -f markdown_preview
    choice="$(printf '%s\n' "${rows[@]}" | fzf \
      --height 85% --layout=reverse --border --prompt "󰍉 " \
      --header "$header (↑/↓ muda; Enter escolhe; Esc cancela)" \
      --with-nth=1 --delimiter=$'\t' \
      --preview 'bash -lc '\''markdown_preview "$1"'\'' _ {2}' \
      --preview-window='right,55%,wrap')" || return 1
    selected="${choice#*$'\t'}"
    [[ -n "$selected" ]] && { printf '%s\n' "$selected"; return 0; }
    return 1
  fi

  if (( ${#files[@]} == 1 )); then
    print_tty ""
    print_tty "$header"
    show_markdown_preview_tty "${files[0]}"
    confirm "Usar este item?" && { printf '%s\n' "${files[0]}"; return 0; }
    return 1
  fi

  if use_gum; then
    choice="$(printf '%s\n' "${displays[@]}" | gum filter --height 18 --placeholder "$header" --prompt "󰍉 " </dev/tty)" || return 1
  else
    choice="$(choose "$header" "${displays[@]}")" || return 1
  fi
  for i in "${!displays[@]}"; do
    if [[ "${displays[$i]}" == "$choice" ]]; then
      print_tty ""
      show_markdown_preview_tty "${files[$i]}"
      confirm "Usar este item?" && { printf '%s\n' "${files[$i]}"; return 0; }
      return 1
    fi
  done
  return 1
}

resolve_obsidian_manual_paths() {
  local manual="$1" raw path base target
  raw="$(clean_manual_path "$manual")"
  [[ -n "$raw" ]] || return 1
  {
    resolve_markdown_manual_paths "$raw" "$OBSIDIAN_PGR_DIR" "$OBSIDIAN_PERSONAL_DIR" \
      "$OBSIDIAN_PGR_DIR/projetos" "$OBSIDIAN_PGR_DIR/reunioes" "$OBSIDIAN_PGR_DIR/reuniões" \
      "$OBSIDIAN_PGR_DIR/01_Projetos" "$OBSIDIAN_PGR_DIR/02_Reuniões"
    [[ "$raw" == PGR/* ]] && resolve_markdown_manual_paths "${raw#PGR/}" "$OBSIDIAN_PGR_DIR"
    [[ "$raw" == Personal/* ]] && resolve_markdown_manual_paths "${raw#Personal/}" "$OBSIDIAN_PERSONAL_DIR"
    if [[ "$raw" != */* ]]; then
      target="$(basename "${raw%.md}")"
      while IFS=$'\t' read -r _ path; do
        base="$(basename "${path%.md}")"
        [[ "${base,,}" == "${target,,}" || "${base,,}" == *"${target,,}"* ]] && printf '%s\n' "$path"
      done < <(obsidian_meeting_note_records)
    fi
    true
  } | awk '!seen[$0]++'
}

choose_obsidian_meeting_note() {
  local prompt="$1" source="${2:-}" day choice query dir manual
  local files=() dirs=()

  day="$(date_from_path "$source")"
  if [[ -n "$day" ]]; then
    mapfile -t files < <(obsidian_meeting_notes_for_date "$day" 12)
    if (( ${#files[@]} > 0 )); then
      info_tty "Notas de reunião de $day (${#files[@]}). Esc cancela e abre outros métodos."
      choose_path_from_files "$prompt — $day" "${files[@]}" && return 0
    fi
  fi

  while true; do
    choice="$(choose "$prompt — como escolher?" \
      "Pesquisar por texto/título" "Últimas 20 reuniões" "Escolher projeto/pasta" "Introduzir caminho manual" "Cancelar")" || return 1
    case "$choice" in
      "Pesquisar por texto/título")
        query="$(input "Texto/data a procurar no caminho/título/conteúdo" "")" || return 1
        mapfile -t files < <(obsidian_meeting_notes_search "$query" 30)
        if (( ${#files[@]} == 0 )); then warn_tty "Sem notas encontradas para: $query"; continue; fi
        choose_path_from_files "$prompt — pesquisa: $query" "${files[@]}" && return 0
        ;;
      "Últimas 20 reuniões")
        mapfile -t files < <(obsidian_meeting_notes 20)
        if (( ${#files[@]} == 0 )); then warn_tty "Não encontrei notas de reunião no Obsidian PGR."; return 1; fi
        choose_path_from_files "$prompt — últimas 20" "${files[@]}" && return 0
        ;;
      "Escolher projeto/pasta")
        mapfile -t dirs < <(obsidian_meeting_dirs)
        if (( ${#dirs[@]} == 0 )); then warn_tty "Não encontrei pastas de reuniões."; continue; fi
        dir="$(choose_path_from_files "Pasta de reuniões" "${dirs[@]}")" || continue
        mapfile -t files < <(obsidian_meeting_notes_in_dir "$dir" 30)
        if (( ${#files[@]} == 0 )); then warn_tty "Sem notas .md nesta pasta: $(display_path "$dir")"; continue; fi
        choose_path_from_files "$prompt — $(display_path "$dir")" "${files[@]}" && return 0
        ;;
      "Introduzir caminho manual")
        manual="$(input "Caminho, nome ou [[wikilink]] da nota" "")" || return 1
        [[ -z "$manual" ]] && continue
        mapfile -t files < <(resolve_obsidian_manual_paths "$manual")
        if (( ${#files[@]} == 0 )); then
          warn_tty "Nota não existe: $manual"
          warn_tty "Podes usar caminho absoluto, relativo a $OBSIDIAN_PGR_DIR, ~/, ou [[wikilink]]."
          continue
        fi
        choose_path_from_files "$prompt — caminho manual" "${files[@]}" && return 0
        ;;
      "Cancelar"|"") return 1 ;;
    esac
  done
}

note_date() {
  local note="$1" base
  base="$(basename "$note")"
  if [[ "$base" =~ ([0-9]{4}-[0-9]{2}-[0-9]{2}) ]]; then printf '%s' "${BASH_REMATCH[1]}"; else date +%F; fi
}

ensure_daily_note() {
  local day="$1" daily="$OBSIDIAN_DAILY_DIR/${day}.md"
  if [[ ! -f "$daily" ]]; then
    mkdir -p "$(dirname "$daily")"
    cat > "$daily" <<EOF
---
tipo: daily
data: "${day}"
tags: [daily]
---

# ${day}

## Foco
- 

## Reuniões
- 

## Notas
- 

## Ações Todoist
- 
EOF
  fi
  printf '%s' "$daily"
}

append_daily_entry() {
  local note="$1" md="${2:-}" day daily title link line
  day="$(note_date "$note")"
  daily="$(ensure_daily_note "$day")"
  title="$(basename "${note%.md}")"
  link="[[${title}|${title}]]"
  if grep -qF "$link" "$daily"; then
    info "Daily já contém link: $link"
    return 0
  fi
  line="- ${link} — nota de reunião sintetizada/atualizada."
  [[ -n "$md" ]] && line+=" Fonte: \`${md}\`."
  {
    echo
    echo "## Reuniões processadas"
    echo "$line"
  } >> "$daily"
  info "Entrada adicionada à Daily: $daily"
}

run_ai_obsidian_merge() {
  local md="$1" note="$2" output="$3" hints="${4:-}" key audio sys prompt rc extra_hints=""
  local ai_cmd=()
  [[ -f "$md" ]] || { err "Transcrição não existe: $md"; return 1; }
  [[ -f "$note" ]] || { err "Nota Obsidian não existe: $note"; return 1; }
  has "$REUNIOES_AI_CMD" || { err "Comando de IA não encontrado: $REUNIOES_AI_CMD"; return 1; }
  mkdir -p "$(dirname "$output")"
  key="$(key_from_path "$md")"
  audio="$(audio_for_key "$key")"
  sys="És assistente de reuniões técnicas da PGR. Fazes merge de uma transcrição crua numa nota Obsidian existente. Preservas factos, screenshots/embeds e frontmatter útil. O sistema ativo é Obsidian + Todoist. Logseq está congelado. NUNCA inventas factos. Devolves SÓ a nota Obsidian completa em Markdown."
  if [[ -n "$hints" ]]; then
    extra_hints="$(cat <<EOF

Indicações do Dias para este merge (prioritárias, mas sem inventar factos):
${hints}
EOF
)"
  fi
  prompt="$(cat <<EOF
Atualiza a NOTA OBSIDIAN existente com a TRANSCRIÇÃO anexada.${extra_hints}

Objetivo:
- Simplificar e agregar o importante.
- Não perder nada importante.
- Preservar screenshots/embeds já existentes na nota.
- Preservar frontmatter e atualizar, se necessário:
  estado: "sintetizada"
  fonte_transcricao: "${md}"
  audio: "${audio}"
- Usar apenas Obsidian + Todoist.

Estrutura recomendada para NOTA GERADA (os templates continuam mínimos):
# Título

> [!summary] Resumo
> - Essencial da reunião.

## Objetivo
## Pontos principais

> [!important] Decisões / orientações
> - Decisões suportadas pela transcrição.

> [!todo] Ações Todoist
> - Ações reais.

> [!question] Follow-ups / dúvidas
> - Pontos a confirmar.

## Fontes
## Palavras-chave

Regras:
- Substituir qualquer "Ações para TickTick" ou "Ações TickTick" por "Ações Todoist".
- Remover referências a Logseq como destino. Manter Logseq só se for fonte histórica explícita.
- Não apagar imagens/embeds existentes.
- Não deixar placeholders vazios se houver conteúdo na transcrição.
- A nota gerada pode e deve ser bonita: callouts, resumo, subtítulos e agregação do importante.
- Não transformar isto num template pesado; enriquecer só a nota final.
- Não escrever nada fora da nota final.
EOF
)"
  ai_cmd_base ai_cmd
  info "A fazer merge Obsidian com IA: $key -> $(basename "$note")"
  set +e
  "${ai_cmd[@]}" --system-prompt "$sys" "@$note" "@$md" "$prompt" > "$output.tmp" 2> "$output.err"
  rc=$?
  set -e
  if [[ -s "$output.tmp" ]]; then
    if (( rc != 0 )); then warn "IA saiu com código $rc, mas devolveu conteúdo; vou guardar."; fi
    mv -- "$output.tmp" "$output"
    rm -f -- "$output.err"
    return 0
  fi
  err "A IA não devolveu conteúdo. Log: $output.err"
  rm -f -- "$output.tmp"
  return 1
}

draft_obsidian_note_ai() {
  local md="${1:-}" output="${2:-}" hints="${3:-${REUNIOES_AI_HINTS:-}}" key ts interactive=false
  init_project_dirs
  if [[ -z "$md" ]]; then
    interactive=true
    md="$(choose_transcription_file "Transcrição para gerar rascunho Obsidian")" || { pause; return; }
  fi
  [[ -f "$md" ]] || { err "Transcrição não existe: $md"; return 1; }
  if [[ "$interactive" == true ]]; then
    hints="$(textarea "Indicações opcionais para o agente IA desta reunião")"
  fi
  key="$(key_from_path "$md")"
  ts="$(date +%Y%m%d-%H%M%S)"
  output="${output:-$BACKUP_DIR/${key}.obsidian-ia-${ts}.md}"
  if [[ -e "$output" ]]; then
    if [[ "$interactive" == true ]]; then confirm "Já existe $output. Sobrescrever?" || return 0
    else err "Destino já existe: $output"; return 1; fi
  fi
  run_ai_obsidian_draft "$md" "$output" "$hints" || { [[ "$interactive" == true ]] && pause; return 1; }
  info "Rascunho Obsidian gerado: $output"
  if [[ "$interactive" == true ]]; then
    if confirm "Copiar para o clipboard?"; then
      copy_to_clipboard "$output" && info "Copiado para o clipboard." || warn "Não encontrei wl-copy/xclip/xsel/pbcopy. Copia manualmente: $output"
    fi
    if confirm "Mostrar resultado agora?"; then sed -n '1,220p' "$output"; fi
    pause
  else
    printf '%s\n' "$output"
  fi
}

merge_transcription_into_obsidian() {
  local md="${1:-}" note="${2:-}" key ts draft backup hints="${3:-${REUNIOES_AI_HINTS:-}}" interactive=false
  init_project_dirs
  if [[ -z "$md" ]]; then interactive=true; md="$(choose_transcription_file "Transcrição a juntar à nota Obsidian")" || { pause; return; }; fi
  if [[ -z "$note" ]]; then interactive=true; note="$(choose_obsidian_meeting_note "Nota Obsidian existente" "$md")" || { pause; return; }; fi
  [[ -f "$md" ]] || { err "Transcrição não existe: $md"; return 1; }
  [[ -f "$note" ]] || { err "Nota Obsidian não existe: $note"; return 1; }
  if [[ "$interactive" == true ]]; then hints="$(textarea "Indicações opcionais para o agente IA neste merge")"; fi
  key="$(key_from_path "$md")"
  ts="$(date +%Y%m%d-%H%M%S)"
  draft="$BACKUP_DIR/${key}.obsidian-merge-${ts}.md"
  run_ai_obsidian_merge "$md" "$note" "$draft" "$hints" || { pause; return 1; }
  info "Draft de merge gerado: $draft"
  if [[ "$interactive" != true ]] || confirm "Aplicar este merge à nota Obsidian?"; then
    backup="$BACKUP_DIR/$(basename "${note%.md}").obsidian-before-merge-${ts}.md"
    cp --preserve=timestamps -- "$note" "$backup"
    cp -- "$draft" "$note"
    info "Nota atualizada: $note"
    info "Backup: $backup"
    if [[ "$interactive" == true ]]; then
      confirm "Adicionar entrada na Daily?" && append_daily_entry "$note" "$md"
      confirm "Extrair ações para Todoist agora?" && create_todoist_tasks_from_file "$note"
    fi
  else
    warn "Merge não aplicado. Draft mantido: $draft"
  fi
  [[ "$interactive" == true ]] && pause
}

extract_todoist_tasks() {
  local note="$1" output="$2" sys prompt rc
  local ai_cmd=()
  [[ -f "$note" ]] || { err "Nota não existe: $note"; return 1; }
  has "$REUNIOES_AI_CMD" || { err "Comando de IA não encontrado: $REUNIOES_AI_CMD"; return 1; }
  mkdir -p "$(dirname "$output")"
  sys="Extrais ações concretas de notas de reunião PGR para Todoist. Devolves só uma lista de tarefas, uma por linha, sem explicações."
  prompt="$(cat <<EOF
Lê a nota Obsidian anexada e extrai apenas ações reais para Todoist.

Regras:
- Uma tarefa por linha.
- Cada linha começa por "- ".
- Começar com verbo no infinitivo/imperativo.
- Incluir contexto mínimo entre parêntesis quando necessário.
- Não criar tarefas vagas como "acompanhar" sem objeto claro.
- Se uma tarefa tiver prazo claro, inclui-o no texto de forma humana.
- Se não houver ações reais, devolve exatamente: Sem ações.
EOF
)"
  ai_cmd_base ai_cmd
  set +e
  "${ai_cmd[@]}" --system-prompt "$sys" "@$note" "$prompt" > "$output.tmp" 2> "$output.err"
  rc=$?
  set -e
  if [[ -s "$output.tmp" ]]; then
    if (( rc != 0 )); then warn "IA saiu com código $rc, mas devolveu conteúdo; vou guardar."; fi
    mv -- "$output.tmp" "$output"
    rm -f -- "$output.err"
    return 0
  fi
  err "A IA não devolveu ações. Log: $output.err"
  rm -f -- "$output.tmp"
  return 1
}

todoist_project_id() {
  local name="${1:-$TODOIST_PROJECT_DEFAULT}"
  [[ -n "$name" ]] || return 0
  if [[ "$name" =~ ^[A-Za-z0-9_-]{8,}$ ]]; then printf '%s' "$name"; return 0; fi
  has "$TODOIST_PROJECTS_BIN" || return 1
  "$TODOIST_PROJECTS_BIN" 2>/dev/null | python3 -c 'import re,sys; name=sys.argv[1].strip().lower();
for line in sys.stdin:
    m=re.match(r"- (.*) \[(.*)\]$", line.strip())
    if m and m.group(1).strip().lower()==name:
        print(m.group(2).strip()); raise SystemExit(0)
raise SystemExit(1)' "$name"
}

create_todoist_tasks_from_file() {
  local note="${1:-}" ts tasks_file project_name project_id due line title created=0 add_cmd=()
  if [[ -z "$note" ]]; then note="$(choose_obsidian_meeting_note "Nota Obsidian para extrair ações")" || { pause; return; }; fi
  [[ -f "$note" ]] || { err "Nota não existe: $note"; return 1; }
  load_todoist_env
  has "$TODOIST_ADD_BIN" || { err "Todoist helper não encontrado: $TODOIST_ADD_BIN"; return 1; }
  ts="$(date +%Y%m%d-%H%M%S)"
  tasks_file="$BACKUP_DIR/$(basename "${note%.md}").todoist-${ts}.txt"
  extract_todoist_tasks "$note" "$tasks_file" || { pause; return 1; }
  echo; sed -n '1,120p' "$tasks_file"; echo
  if grep -qxF "Sem ações." "$tasks_file"; then warn "Sem ações reais para criar."; pause; return 0; fi
  confirm "Criar estas tarefas no Todoist?" || { info "Lista guardada: $tasks_file"; pause; return 0; }
  project_name="$(input "Projeto Todoist (nome ou id; vazio = inbox)" "$TODOIST_PROJECT_DEFAULT")"
  project_id="$(todoist_project_id "$project_name" || true)"
  if [[ -n "$project_name" && -z "$project_id" ]]; then
    warn "Projeto Todoist não encontrado: $project_name — vou criar na Inbox."
  fi
  due="$(input "Prazo comum opcional (ex.: today, tomorrow, next week)" "")"
  while IFS= read -r line; do
    [[ "$line" == "- "* ]] || continue
    title="${line#- }"
    [[ -n "$title" ]] || continue
    add_cmd=("$TODOIST_ADD_BIN" "$title" --desc "Fonte Obsidian: $note")
    [[ -n "$project_id" ]] && add_cmd+=(--project "$project_id")
    [[ -n "$due" ]] && add_cmd+=(--due "$due")
    "${add_cmd[@]}" >/dev/null
    created=$((created + 1))
  done < "$tasks_file"
  info "Tarefas criadas no Todoist: $created"
  pause
}

sanitize_transcription_ai() { draft_obsidian_note_ai "$@"; }

all_audio_files() {
  init_project_dirs
  shopt -s nullglob
  local audio
  for audio in "$WAV_DIR"/*.wav "$OPUS_DIR"/*.opus; do [[ -f "$audio" ]] && printf '%s\n' "$audio"; done | sort -r
}

choose_any_audio_file() {
  local prompt="$1"
  mapfile -t files < <(all_audio_files)
  if (( ${#files[@]} == 0 )); then warn "Não há ficheiros áudio."; return 1; fi
  choose "$prompt" "${files[@]}"
}

retranscribe_job() {
  local audio="$1" tmp_output="$2" final_output="$3" lang="$4" model="$5" chunks="$6" archive="$7" backup rc=0
  init_project_dirs
  info "A refazer transcrição: $audio"
  info "Output temporário: $tmp_output"
  info "Output final: $final_output"
  mkdir -p "$(dirname "$tmp_output")" "$(dirname "$final_output")"
  if [[ -n "$lang" ]]; then
    TRANSCRICOES_DIR="$TRANSCRICOES_DIR" OPUS_DIR="$OPUS_DIR" ARCHIVE_INDEX="$ARCHIVE_INDEX" WHISPER_MODEL="$model" WHISPER_LANGUAGE="$lang" CHUNK_SECONDS="$chunks" ARCHIVE_OPUS="$archive" "$TRANSCRIBER_BIN" "$audio" "$tmp_output" || rc=$?
  else
    TRANSCRICOES_DIR="$TRANSCRICOES_DIR" OPUS_DIR="$OPUS_DIR" ARCHIVE_INDEX="$ARCHIVE_INDEX" WHISPER_MODEL="$model" WHISPER_LANGUAGE="" CHUNK_SECONDS="$chunks" ARCHIVE_OPUS="$archive" "$TRANSCRIBER_BIN" "$audio" "$tmp_output" || rc=$?
  fi
  if (( rc != 0 )); then err "Transcrição falhou com código $rc. Mantido temp/parcial: $tmp_output"; return "$rc"; fi
  if [[ -f "$final_output" ]]; then
    backup="$BACKUP_DIR/$(basename "${final_output%.md}").bak-$(date +%Y%m%d-%H%M%S).md"
    mv -- "$final_output" "$backup"
    info "Transcrição anterior guardada: $backup"
  fi
  mv -- "$tmp_output" "$final_output"
  info "Transcrição refeita: $final_output"
}

retranscribe_audio() {
  local audio key lang archive model chunks final_output tmp_output log_file session cmd
  audio="$(choose_any_audio_file "Áudio para refazer transcrição")" || { pause; return; }
  key="$(key_from_path "$audio")"
  final_output="$(md_for_key "$key")"
  tmp_output="$BACKUP_DIR/${key}.retry-$(date +%Y%m%d-%H%M%S).md"
  log_file="$LOG_DIR/${key}.retranscrever-$(date +%Y%m%d-%H%M%S).log"
  if [[ -f "$final_output" ]]; then warn "Já existe transcrição: $final_output"; confirm "Refazer? A versão atual será guardada em backups/" || return; fi
  lang="$(choose "Língua" "pt" "en" "auto")"; [[ "$lang" == "auto" ]] && lang=""
  model="$(input "Modelo" "$WHISPER_MODEL_DEFAULT")"
  chunks="$(input "Blocos segundos" "$CHUNK_SECONDS_DEFAULT")"
  archive="0"
  if [[ "$audio" == *.wav ]] && confirm "Criar/atualizar OPUS no fim? (mantém WAV)"; then archive="1"; fi
  if has tmux && confirm "Correr em background/tmux? (recomendado se estás remoto/telemóvel)"; then
    session="reunioes_refazer_$(date +%Y%m%d_%H%M%S)"
    printf -v cmd '%q ' "$(reunioes_self)" refazer-job "$audio" "$tmp_output" "$final_output" "$lang" "$model" "$chunks" "$archive"
    tmux new-session -d -s "$session" "$cmd > $(printf '%q' "$log_file") 2>&1; echo EXIT:\$? >> $(printf '%q' "$log_file")"
    info "Job lançado em tmux: $session"
    info "Log: $log_file"
  else
    retranscribe_job "$audio" "$tmp_output" "$final_output" "$lang" "$model" "$chunks" "$archive"
  fi
  pause
}

archive_candidates() {
  init_project_dirs
  shopt -s nullglob
  local wav key
  for wav in "$WAV_DIR"/*.wav; do
    [[ -f "$wav" ]] || continue
    key="$(key_from_path "$wav")"
    [[ -f "$(md_for_key "$key")" && ! -f "$(opus_for_key "$key")" ]] && printf '%s\n' "$wav"
  done | sort
}

make_opus() {
  local wav="$1" key opus
  init_project_dirs
  key="$(key_from_path "$wav")"
  opus="$(opus_for_key "$key")"
  ffmpeg -hide_banner -loglevel error -y -i "$wav" \
    -c:a libopus -b:a "$OPUS_BITRATE" -vbr on -compression_level 10 -ac 1 \
    "$opus"
  archive_record_opus "$wav" "$opus"
}

archive_one() {
  mapfile -t files < <(archive_candidates)
  if (( ${#files[@]} == 0 )); then warn "Não há WAV com MD e sem OPUS."; pause; return; fi
  local wav
  wav="$(choose "WAV para arquivar em OPUS" "${files[@]}")"; [[ -n "$wav" ]] || return
  info "A criar OPUS: $wav"; make_opus "$wav"; info "Criado: $(opus_for_key "$(key_from_path "$wav")")"; pause
}

archive_all() {
  mapfile -t files < <(archive_candidates)
  if (( ${#files[@]} == 0 )); then warn "Não há WAV com MD e sem OPUS."; pause; return; fi
  printf '%s\n' "${files[@]}"; echo
  confirm "Criar OPUS para ${#files[@]} ficheiro(s)?" || return
  local wav n=0 total=${#files[@]}
  for wav in "${files[@]}"; do
    n=$((n + 1)); info "[$n/$total] A arquivar: $wav"
    make_opus "$wav" || { err "[$n/$total] Falhou: $wav"; return 1; }
  done
  pause
}

cleanup_candidates() {
  init_project_dirs
  find "$WAV_DIR" -maxdepth 1 -type f -name '*.wav' -mtime +"$KEEP_WAV_DAYS" -print | while read -r wav; do
    key="$(key_from_path "$wav")"
    [[ -f "$(md_for_key "$key")" && -f "$(opus_for_key "$key")" ]] && printf '%s\n' "$wav"
  done
}

cleanup_wavs() {
  local days f
  init_project_dirs
  [[ "$KEEP_WAV_DAYS" =~ ^[0-9]+$ ]] || KEEP_WAV_DAYS=14
  days="$(input "Apagar WAV com mais de quantos dias? (número)" "$KEEP_WAV_DAYS")"
  [[ "$days" =~ ^[0-9]+$ ]] || { warn "Valor inválido: '$days'."; pause; return; }
  KEEP_WAV_DAYS="$days"
  mapfile -t files < <(cleanup_candidates)
  if (( ${#files[@]} == 0 )); then warn "Nenhum WAV elegível. Regra: idade > ${KEEP_WAV_DAYS} dias + MD + OPUS existentes."; pause; return; fi
  echo "Elegíveis para apagar:"; printf '  %s\n' "${files[@]}"; echo
  confirm "Apagar estes ${#files[@]} WAV? (irreversível)" || return
  for f in "${files[@]}"; do archive_mark_removed "$f"; rm -v -- "$f"; done
  pause
}

record_meeting() {
  local timestamp audio_file monitor mic ffmpeg_pid ffmpeg_status recording_stopped=false
  init_project_dirs
  timestamp=$(date +%Y-%m-%d_%H%M)
  local key local_audio_file final_audio_file ffmpeg_log quality_log qc_status
  key="reuniao_${timestamp}"
  local_audio_file="$LOCAL_WAV_DIR/${key}.wav"
  final_audio_file="$WAV_DIR/${key}.wav"
  ffmpeg_log="$LOG_DIR/${key}.gravar.log"
  quality_log="$LOG_DIR/${key}.qualidade.log"
  audio_file="$local_audio_file"
  local mic_gain="${MIC_GAIN:-1.20}" monitor_gain="${MONITOR_GAIN:-0.92}" output_rate="${OUTPUT_RATE:-24000}"
  local mic_filter="${MIC_FILTER:-highpass=f=80,lowpass=f=9000,afftdn=nf=-20,acompressor=threshold=0.09:ratio=3:attack=5:release=90:makeup=3,alimiter=limit=0.92}"
  monitor="$(pactl get-default-sink 2>/dev/null || true)"
  mic="$(pactl get-default-source 2>/dev/null || true)"
  if [[ -z "$monitor" || -z "$mic" ]]; then
    err "Não consegui obter source/sink do PipeWire/PulseAudio via pactl."
    return 1
  fi
  monitor="${monitor}.monitor"

  clear || true
  style "🟡 PREPARAÇÃO DA GRAVAÇÃO"
  cat <<EOF

ESTADO: AINDA NÃO ESTÁ A GRAVAR

Vai gravar para ficheiro local temporário:
  $local_audio_file

Só no fim, depois de parar e validar, será publicado para Syncthing:
  $final_audio_file

Fontes de áudio:
  Sistema/reunião : $monitor
  Microfone       : $mic

Log técnico:
  $ffmpeg_log

Checklist antes de começar:
  1. Estás a ouvir a reunião pelo dispositivo correto.
  2. O microfone certo está seleccionado, se precisares da tua voz.
  3. Quando carregares ENTER abaixo, a gravação começa IMEDIATAMENTE.

Para cancelar agora: Ctrl+C
EOF
  echo
  if [[ "$mic" == "$monitor" ]]; then
    warn "O microfone predefinido é igual ao monitor de saída. Vais gravar áudio do sistema, mas provavelmente NÃO a tua voz por microfone separado."
    confirm "Continuar mesmo assim?" || { warn "Gravação cancelada. Define o microfone correcto no sistema e tenta novamente."; return 0; }
    echo
  fi
  if ( : </dev/tty ) 2>/dev/null; then read -rp "ENTER = COMEÇAR A GRAVAR AGORA... " _ </dev/tty || return
  else read -rp "ENTER = COMEÇAR A GRAVAR AGORA... " _ || return; fi

  stop_recording() {
    [[ "$recording_stopped" == true ]] && return 0
    recording_stopped=true
    printf '\n⏹  A parar gravação e a fechar WAV...\n'
    [[ -n "${ffmpeg_pid:-}" ]] && kill -INT "$ffmpeg_pid" 2>/dev/null || true
  }
  trap stop_recording INT

  ffmpeg -nostdin -hide_banner -nostats -f pulse -i "$monitor" -f pulse -i "$mic" \
    -filter_complex "[0:a]aformat=channel_layouts=mono,volume=${monitor_gain}[mon];[1:a]aformat=channel_layouts=mono,${mic_filter},volume=${mic_gain}[mic];[mon][mic]amix=inputs=2:duration=longest:normalize=0[mix];[mix]alimiter=limit=0.95[out]" \
    -map "[out]" -ar "$output_rate" -c:a pcm_s16le "$audio_file" >"$ffmpeg_log" 2>&1 &
  ffmpeg_pid=$!

  sleep 1
  if ! kill -0 "$ffmpeg_pid" 2>/dev/null; then
    set +e; wait "$ffmpeg_pid"; ffmpeg_status=$?; set -e; trap - INT
    err "A gravação falhou ao arrancar. Ver log: $ffmpeg_log"
    tail -40 "$ffmpeg_log" 2>/dev/null || true
    return "${ffmpeg_status:-1}"
  fi

  printf '\a'
  echo
  style "🔴 GRAVAÇÃO INICIADA"
  echo "A partir deste momento ESTÁ MESMO A GRAVAR."
  echo "Prima ENTER para PARAR, fechar o WAV e correr a verificação de qualidade."
  echo "Ficheiro local: $local_audio_file"
  echo

  local start_epoch now elapsed h m s cursor_hidden=false
  if has tput && [[ -t 1 ]] && tput civis 2>/dev/null; then cursor_hidden=true; fi
  start_epoch="$(date +%s)"
  while kill -0 "$ffmpeg_pid" 2>/dev/null; do
    now="$(date +%s)"
    elapsed=$((now - start_epoch))
    h=$((elapsed / 3600)); m=$(((elapsed % 3600) / 60)); s=$((elapsed % 60))
    printf '\r\033[K🔴 A GRAVAR há %02d:%02d:%02d  — ENTER = PARAR' "$h" "$m" "$s"
    if ( : </dev/tty ) 2>/dev/null; then
      if read -r -s -t 1 _ </dev/tty; then stop_recording; break; fi
    else
      if read -r -s -t 1 _; then stop_recording; break; fi
    fi
    [[ "$recording_stopped" == true ]] && break
  done
  [[ "$cursor_hidden" == true ]] && tput cnorm 2>/dev/null || true
  printf '\r\033[K'

  set +e; wait "$ffmpeg_pid"; ffmpeg_status=$?; set -e; trap - INT
  if [[ $ffmpeg_status -ne 0 && $recording_stopped != true ]]; then err "A gravação terminou de forma inesperada. Ver log: $ffmpeg_log"; return "$ffmpeg_status"; fi
  if [[ ! -s "$local_audio_file" ]]; then err "WAV local vazio/inexistente: $local_audio_file"; return 1; fi
  if has ffprobe && ! ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$local_audio_file" >/dev/null; then
    err "WAV não validou com ffprobe: $local_audio_file"
    return 1
  fi
  set +e
  audio_quality_check "$local_audio_file" "$quality_log"
  qc_status=$?
  set -e
  if (( qc_status > 0 )); then
    warn "A verificação automática levantou ${qc_status} aviso(s). Log: $quality_log"
    if ! confirm "Publicar este WAV para Syncthing mesmo assim?"; then
      warn "WAV mantido apenas localmente: $local_audio_file"
      warn "Nada foi publicado para Syncthing. Podes rever/apagar/cortar manualmente."
      pause
      return 0
    fi
  fi
  publish_wav "$local_audio_file" "$final_audio_file"
  echo; echo "✅ Gravação terminada, verificada e publicada para Syncthing"
  echo "   WAV: $final_audio_file"; echo
  echo "Para transcrever: reunioes transcrever"
  printf '  PT: WHISPER_MODEL=large-v3 WHISPER_LANGUAGE=pt transcrever-audio %q %q\n' "$final_audio_file" "$(md_for_key "$(key_from_path "$final_audio_file")")"
  pause
}

open_folder() { if has xdg-open; then xdg-open "$REUNIOES_DIR" >/dev/null 2>&1 & disown || true; fi; info "$REUNIOES_DIR"; pause; }

remote_session_prefix="reunioes_remote_"

remote_pending_audio() {
  init_project_dirs
  shopt -s nullglob
  local audio key priority
  # Ordenar por base ISO e preferir WAV publicado por Syncthing. OPUS fica como fallback.
  for audio in "$WAV_DIR"/*.wav "$OPUS_DIR"/*.opus; do
    [[ -f "$audio" ]] || continue
    key="$(key_from_path "$audio")"
    [[ -f "$(md_for_key "$key")" ]] && continue
    [[ "$audio" == *.wav ]] && priority=0 || priority=1
    printf '%s\t%s\t%s\n' "$key" "$priority" "$audio"
  done | sort -t $'\t' -k1,1 -k2,2n | awk -F '\t' '!seen[$1]++ { print $3 }'
}

remote_running_sessions() {
  has tmux || return 0
  tmux list-sessions -F '#S' 2>/dev/null | grep -E "^${remote_session_prefix}" || true
}

remote_latest_log() {
  local latest_link="$LOG_DIR/remote-latest.log"
  if [[ -e "$latest_link" ]]; then
    readlink -f "$latest_link" 2>/dev/null || printf '%s\n' "$latest_link"
    return 0
  fi
  find "$LOG_DIR" -maxdepth 1 -type f -name '*.remote-*.log' -printf '%T@\t%p\n' 2>/dev/null | sort -nr | awk -F '\t' 'NR == 1 { print $2 }'
}

remote_status() {
  init_project_dirs
  local pending_count running latest
  pending_count="$(remote_pending_audio | wc -l)"
  echo "# Reuniões — estado remoto"
  echo "Host: $(hostname)"
  echo "Projeto: $REUNIOES_DIR"
  echo "Pendentes: $pending_count"
  echo
  echo "## Próximos pendentes"
  if (( pending_count > 0 )); then
    remote_pending_audio | sed 's#^#- #' | head -10
  else
    echo "- nenhum"
  fi
  echo
  echo "## Jobs activos"
  running="$(remote_running_sessions || true)"
  if [[ -n "$running" ]]; then printf '%s\n' "$running" | sed 's#^#- #'; else echo "- nenhum"; fi
  echo
  latest="$(remote_latest_log || true)"
  echo "## Último log"
  if [[ -n "$latest" ]]; then echo "$latest"; else echo "- nenhum"; fi
}

remote_start() {
  init_project_dirs
  if ! has tmux; then
    err "tmux não está instalado/disponível."
    return 1
  fi

  local running audio key session final_output tmp_output log_file archive lang model chunks cmd latest_link
  running="$(remote_running_sessions || true)"
  if [[ -n "$running" ]]; then
    warn "Já existe job remoto activo:"
    printf '%s\n' "$running" | sed 's#^#  - #'
    return 1
  fi

  audio="$(remote_pending_audio | head -1)"
  if [[ -z "$audio" ]]; then
    info "Não há áudio pendente para transcrever."
    return 0
  fi

  key="$(key_from_path "$audio")"
  session="${remote_session_prefix}${key}"
  final_output="$(md_for_key "$key")"
  tmp_output="$BACKUP_DIR/${key}.remote-$(date +%Y%m%d-%H%M%S).md"
  log_file="$LOG_DIR/${key}.remote-$(date +%Y%m%d-%H%M%S).log"
  latest_link="$LOG_DIR/remote-latest.log"
  lang="${REMOTE_WHISPER_LANGUAGE:-pt}"
  model="${REMOTE_WHISPER_MODEL:-$WHISPER_MODEL_DEFAULT}"
  chunks="${REMOTE_CHUNK_SECONDS:-$CHUNK_SECONDS_DEFAULT}"
  archive="0"
  [[ "$audio" == *.wav ]] && archive="1"

  ln -sfn "$log_file" "$latest_link"
  printf -v cmd '%q ' "$(reunioes_self)" refazer-job "$audio" "$tmp_output" "$final_output" "$lang" "$model" "$chunks" "$archive"
  tmux new-session -d -s "$session" "$cmd > $(printf '%q' "$log_file") 2>&1; rc=\$?; echo EXIT:\$rc >> $(printf '%q' "$log_file"); exit \$rc"

  echo "✅ Transcrição lançada em background"
  echo "Sessão: $session"
  echo "Áudio: $audio"
  echo "Destino: $final_output"
  echo "Log: $log_file"
}

remote_log() {
  init_project_dirs
  local latest lines
  lines="${1:-80}"
  latest="$(remote_latest_log || true)"
  if [[ -z "$latest" || ! -e "$latest" ]]; then
    warn "Ainda não há log remoto."
    return 1
  fi
  echo "# $latest"
  tail -n "$lines" "$latest"
}

show_help() {
  cat <<EOF
Workflow recomendado

Projeto: $REUNIOES_DIR

Estrutura:
  transcricoes/       transcrições Markdown finais
  audio/wav/          WAV originais/recentes
  audio/opus/         arquivo áudio comprimido
  logs/               logs de retranscrição/migração
  backups/            transcrições antigas, parciais e retries
  .arquivo-audio.tsv  índice de poupança WAV -> OPUS

Comandos:
  reunioes gravar
  reunioes status
  reunioes transcrever
  reunioes refazer
  reunioes obsidian-merge  # junta transcrição a nota Obsidian existente
  reunioes obsidian-draft  # gera rascunho Obsidian com IA/Pi
  reunioes todoist-acoes  # extrai ações de nota Obsidian para Todoist
  reunioes arquivar
  reunioes arquivar-tudo
  reunioes limpar
  reunioes remote-status  # estado para uso remoto/Telegram
  reunioes remote-start   # lança próxima transcrição em tmux/background
  reunioes remote-log     # últimas linhas do log remoto
  reunioes setup          # garante/cria estrutura; idempotente
  reunioes help
EOF
  pause
}

transcriptions_menu() {
  while true; do
    clear || true
    style "📝 Transcrições"
    info "Projeto: $REUNIOES_DIR"; echo
    choice="$(choose "Escolhe" \
      "Transcrever áudio pendente" "Refazer transcrição" "Voltar")"
    case "$choice" in
      "Transcrever áudio pendente") transcribe_pending ;;
      "Refazer transcrição") retranscribe_audio ;;
      "Voltar"|"") break ;;
    esac
  done
}

notes_menu() {
  while true; do
    clear || true
    style "🧠 Obsidian + Todoist"
    info "Projeto: $REUNIOES_DIR"; echo
    choice="$(choose "Escolhe" \
      "Juntar transcrição a nota Obsidian" "Gerar rascunho Obsidian com IA" \
      "Extrair ações para Todoist" "Abrir Todoist TUI" "Voltar")"
    case "$choice" in
      "Juntar transcrição a nota Obsidian") merge_transcription_into_obsidian ;;
      "Gerar rascunho Obsidian com IA") draft_obsidian_note_ai ;;
      "Extrair ações para Todoist") create_todoist_tasks_from_file ;;
      "Abrir Todoist TUI") if has "$TODOIST_TUI_BIN"; then "$TODOIST_TUI_BIN"; else err "Todoist TUI não encontrado: $TODOIST_TUI_BIN"; pause; fi ;;
      "Voltar"|"") break ;;
    esac
  done
}

archive_menu() {
  while true; do
    clear || true
    style "🗄 Arquivo e limpeza"
    info "Projeto: $REUNIOES_DIR"; echo
    choice="$(choose "Escolhe" \
      "Arquivar um WAV para OPUS" "Arquivar todos os WAV elegíveis" "Limpar WAV antigos" "Voltar")"
    case "$choice" in
      "Arquivar um WAV para OPUS") archive_one ;;
      "Arquivar todos os WAV elegíveis") archive_all ;;
      "Limpar WAV antigos") cleanup_wavs ;;
      "Voltar"|"") break ;;
    esac
  done
}

remote_menu() {
  while true; do
    clear || true
    style "🌐 Remoto / Telegram"
    info "Projeto: $REUNIOES_DIR"; echo
    choice="$(choose "Escolhe" \
      "Remote status" "Remote start" "Remote log" "Voltar")"
    case "$choice" in
      "Remote status") remote_status || true; pause ;;
      "Remote start") remote_start || true; pause ;;
      "Remote log") remote_log || true; pause ;;
      "Voltar"|"") break ;;
    esac
  done
}

utilities_menu() {
  while true; do
    clear || true
    style "🔧 Utilitários"
    info "Projeto: $REUNIOES_DIR"; echo
    choice="$(choose "Escolhe" \
      "Abrir pasta" "Setup / garantir estrutura" "Help" "Voltar")"
    case "$choice" in
      "Abrir pasta") open_folder ;;
      "Setup / garantir estrutura") init_project_dirs; info "Estrutura do projeto garantida: $REUNIOES_DIR"; pause ;;
      "Help") show_help ;;
      "Voltar"|"") break ;;
    esac
  done
}

main_menu() {
  init_project_dirs
  while true; do
    clear || true
    style "🎙 Reuniões"
    info "Projeto: $REUNIOES_DIR"; echo
    choice="$(choose "Escolhe" \
      "🎙 Gravar nova reunião" "📊 Ver estado" "📝 Transcrições" "🧠 Obsidian + Todoist" \
      "🗄 Arquivo e limpeza" "🌐 Remoto / Telegram" "🔧 Utilitários" "Sair")"
    case "$choice" in
      "🎙 Gravar nova reunião") record_meeting ;;
      "📊 Ver estado") show_status; pause ;;
      "📝 Transcrições") transcriptions_menu ;;
      "🧠 Obsidian + Todoist") notes_menu ;;
      "🗄 Arquivo e limpeza") archive_menu ;;
      "🌐 Remoto / Telegram") remote_menu ;;
      "🔧 Utilitários") utilities_menu ;;
      "Sair"|"") break ;;
    esac
  done
}

cmd="${1:-menu}"
case "$cmd" in
  menu) main_menu ;;
  setup) init_project_dirs; info "Estrutura do projeto garantida: $REUNIOES_DIR" ;;
  gravar) record_meeting ;;
  status) show_status ;;
  transcrever) transcribe_pending ;;
  refazer) retranscribe_audio ;;
  refazer-job) shift; retranscribe_job "$@" ;;
  sanitizar|resumir|obsidian-draft) shift; draft_obsidian_note_ai "$@" ;;
  obsidian-merge) shift; merge_transcription_into_obsidian "$@" ;;
  todoist-acoes|todoist-actions) shift; create_todoist_tasks_from_file "$@" ;;
  arquivar) archive_one ;;
  arquivar-tudo) archive_all ;;
  limpar) cleanup_wavs ;;
  remote-status) remote_status ;;
  remote-start) remote_start ;;
  remote-log) shift; remote_log "${1:-80}" ;;
  help|-h|--help) show_help ;;
  *) err "Comando desconhecido: $cmd"; echo "Usa: reunioes help"; exit 2 ;;
esac
