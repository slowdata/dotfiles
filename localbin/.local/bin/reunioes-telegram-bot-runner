#!/usr/bin/env bash
set -euo pipefail

SECRETS_ENV="${SECRETS_ENV:-$HOME/.config/secrets/env}"
BOT="${BOT:-$HOME/.local/bin/reunioes-telegram-bot}"

if [[ ! -f "$SECRETS_ENV" ]]; then
  echo "ERRO: ficheiro de segredos não existe: $SECRETS_ENV" >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "$SECRETS_ENV"
set +a

exec "$BOT"
