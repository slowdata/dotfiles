#!/usr/bin/env bash
set -euo pipefail

colors_file="${OMARCHY_TMUX_COLORS:-$HOME/.config/omarchy/current/theme/colors.toml}"
out_file="${OMARCHY_TMUX_CONF:-$HOME/.config/tmux/omarchy-theme.conf}"

if [[ ! -f "$colors_file" ]]; then
  echo "tmux-omarchy-theme: missing colors file: $colors_file" >&2
  exit 1
fi

color() {
  local key="$1" fallback="${2:-}"
  local value
  value=$(awk -F'"' -v key="$key" '
    $0 ~ "^[[:space:]]*" key "[[:space:]]*=" { print $2; exit }
  ' "$colors_file")
  printf '%s\n' "${value:-$fallback}"
}

bg=$(color background '#FFFCF0')
fg=$(color foreground '#100F0F')
# Use a paper-like selection background on light themes, but use color0 as a
# dark surface on dark themes. Some dark Omarchy themes use accent colors for
# selection_background, which is too loud for tmux module text blocks.
if [[ -f "$(dirname "$colors_file")/light.mode" ]]; then
  muted=$(color selection_background "$(color color0 '#CECDC3')")
else
  muted=$(color color0 "$(color selection_background '#32344A')")
fi
subtle=$(color color7 '#B7B5AC')
blue=$(color accent "$(color color4 '#205EA6')")
red=$(color color1 '#D14D41')
yellow=$(color color3 '#D0A215')
green=$(color color2 '#879A39')
cyan=$(color color6 '#3AA99F')

mkdir -p "$(dirname "$out_file")"
tmp=$(mktemp)
cat >"$tmp" <<EOF
##### Theme - Omarchy dynamic (generated by tmux-omarchy-theme)
# Source: $colors_file
# Do not edit this file directly; edit tmux-omarchy-theme instead.

set -g status-style "bg=$bg,fg=$fg"
set -g message-style "bg=$muted,fg=$fg"
set -g message-command-style "bg=$muted,fg=$fg"
# Keep copy-mode/selection contrast high across themes.
set -g mode-style "bg=$muted,fg=$fg,bold,underscore"

set -g pane-border-style "fg=$muted"
set -g pane-active-border-style "fg=$blue"
set -g display-panes-colour "$muted"
set -g display-panes-active-colour "$blue"

set -g window-status-style "bg=$bg,fg=$subtle"
set -g window-status-format " #[fg=$subtle]#I #[fg=$fg]#W "
set -g window-status-current-style "bg=$muted,fg=$fg,bold"
set -g window-status-current-format " #[bg=$fg,fg=$bg,bold] #I #[default]"
set -g window-status-bell-style "bg=$yellow,fg=$fg,bold"
set -g window-status-activity-style "bg=$bg,fg=$blue"

set -g status-left-style "bg=$blue,fg=$bg,bold"
set -g status-left " #S "
set -g status-right-style "bg=$bg,fg=$fg"

set -g @omarchy_status_copy "#[fg=$bg,bg=$cyan,bold] COPY #[fg=$fg,bg=$muted] mode "
set -g @omarchy_status_prefix "#[fg=$bg,bg=$red,bold] PREFIX #[fg=$fg,bg=$muted] on "
set -g @omarchy_status_zoom "#[fg=$fg,bg=$yellow,bold] ZOOM #[fg=$fg,bg=$muted] pane "
set -g @omarchy_status_app "#[fg=$bg,bg=$green,bold]  #[fg=$fg,bg=$muted] #{pane_current_command} "
set -g @omarchy_status_host "#[fg=$bg,bg=$blue,bold] 󰒋 #[fg=$fg,bg=$muted] #H "
set -g status-right "#{?pane_in_mode,#{E:@omarchy_status_copy},}#{?client_prefix,#{E:@omarchy_status_prefix},}#{?window_zoomed_flag,#{E:@omarchy_status_zoom},}#{E:@omarchy_status_app}#{E:@omarchy_status_host}"

set -g status-format[0] "#[align=left fill=$bg]#[bg=$blue,fg=$bg,bold]#{T;=/#{status-left-length}:status-left}#[default]#{W:#{E:window-status-format},#{E:window-status-current-format}}#[align=right fill=$bg]#{T;=/#{status-right-length}:status-right}"
EOF
mv "$tmp" "$out_file"

if [[ "${TMUX_OMARCHY_NO_APPLY:-0}" != "1" ]] && command -v tmux >/dev/null 2>&1 && tmux list-sessions >/dev/null 2>&1; then
  tmux source-file "$out_file"
fi
