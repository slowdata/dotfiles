#!/usr/bin/env bash
set -euo pipefail

colors_file="${OMARCHY_TMUX_COLORS:-$HOME/.config/omarchy/current/theme/colors.toml}"
out_file="${OMARCHY_TMUX_CONF:-$HOME/.config/tmux/omarchy-theme.conf}"

if [[ ! -f "$colors_file" ]]; then
  echo "tmux-omarchy-theme: missing colors file: $colors_file" >&2
  exit 1
fi

color() {
  local key="$1" fallback="${2:-}"
  local value
  value=$(awk -F'"' -v key="$key" '
    $0 ~ "^[[:space:]]*" key "[[:space:]]*=" { print $2; exit }
  ' "$colors_file")
  printf '%s\n' "${value:-$fallback}"
}

bg=$(color background '#FFFCF0')
fg=$(color foreground '#100F0F')

lighten_hex() {
  local hex="${1#\#}" amount="${2:-18}"
  python - "$hex" "$amount" <<'PY'
import sys
hex_value = sys.argv[1]
amount = int(sys.argv[2])
r = min(255, int(hex_value[0:2], 16) + amount)
g = min(255, int(hex_value[2:4], 16) + amount)
b = min(255, int(hex_value[4:6], 16) + amount)
print(f"#{r:02X}{g:02X}{b:02X}")
PY
}

theme_dir=$(dirname "$colors_file")

# Use a paper-like selection background on light themes. On dark themes, avoid
# color0 because several Omarchy themes define it as pure black, which makes
# tmux blocks look harsh and low-contrast. Use a slightly lifted surface instead.
is_light=0
if [[ -f "$theme_dir/light.mode" ]]; then
  is_light=1
  surface="$bg"
  muted=$(color selection_background "$(color color0 '#CECDC3')")
  selection_fg="$fg"
else
  # Dark Omarchy themes often use a very flat terminal background. Give tmux
  # its own lifted surfaces so status/modules/active-window are visible.
  surface=$(lighten_hex "$bg" 8)
  muted=$(lighten_hex "$bg" 28)
  selection_fg="$bg"
fi
subtle=$(color color7 '#B7B5AC')
blue=$(color accent "$(color color4 '#205EA6')")
red=$(color color1 '#D14D41')
yellow=$(color color6 "$(color color3 '#D0A215')")
green=$(color color2 '#879A39')
cyan=$(color color14 "$(color color6 '#3AA99F')")

mkdir -p "$(dirname "$out_file")"
tmp=$(mktemp)
cat >"$tmp" <<EOF
##### Theme - Omarchy dynamic (generated by tmux-omarchy-theme)
# Source: $colors_file
# Do not edit this file directly; edit tmux-omarchy-theme instead.

set -g status-style "bg=$surface,fg=$fg"
set -g message-style "bg=$muted,fg=$fg"
set -g message-command-style "bg=$muted,fg=$fg"
# Keep copy-mode/selection contrast high across themes.
set -g mode-style "bg=$yellow,fg=$selection_fg,bold"
set -gw copy-mode-selection-style "bg=$yellow,fg=$selection_fg,bold"
set -gw copy-mode-mark-style "bg=$red,fg=$bg,bold"
set -gw copy-mode-match-style "bg=$cyan,fg=$fg,bold"
set -gw copy-mode-current-match-style "bg=$blue,fg=$bg,bold"
set -g menu-style "bg=$surface,fg=$fg"
set -g menu-selected-style "bg=$blue,fg=$bg,bold"
set -g menu-border-style "fg=$muted"
set -g popup-style "bg=$surface,fg=$fg"
set -g popup-border-style "fg=$blue"

set -g pane-border-style "fg=$muted"
set -g pane-active-border-style "fg=$blue"
set -g display-panes-colour "$muted"
set -g display-panes-active-colour "$blue"
EOF

if (( is_light )); then
  cat >>"$tmp" <<EOF
set -g window-status-style "bg=$surface,fg=$subtle"
set -g window-status-format " #[fg=$subtle]#I #[fg=$fg]#W "
set -g window-status-current-style "bg=$muted,fg=$fg,bold"
set -g window-status-current-format " #[bg=$fg,fg=$bg,bold] #I #[default]"
set -g window-status-bell-style "bg=$yellow,fg=$fg,bold"
set -g window-status-activity-style "bg=$surface,fg=$blue"

set -g status-left-style "bg=$blue,fg=$bg,bold"
set -g status-left " #S "
set -g status-right-style "bg=$surface,fg=$fg"

set -g @omarchy_status_copy "#[fg=$bg,bg=$cyan,bold] COPY #[fg=$fg,bg=$muted] mode "
set -g @omarchy_status_prefix "#[fg=$bg,bg=$red,bold] PREFIX #[fg=$fg,bg=$muted] on "
set -g @omarchy_status_zoom "#[fg=$fg,bg=$yellow,bold] ZOOM #[fg=$fg,bg=$muted] pane "
set -g @omarchy_status_app "#[fg=$bg,bg=$green,bold]  #[fg=$fg,bg=$muted] #{pane_current_command} "
set -g @omarchy_status_host "#[fg=$bg,bg=$blue,bold] 󰒋 #[fg=$fg,bg=$muted] #H "
set -g status-right "#{?pane_in_mode,#{E:@omarchy_status_copy},}#{?client_prefix,#{E:@omarchy_status_prefix},}#{?window_zoomed_flag,#{E:@omarchy_status_zoom},}#{E:@omarchy_status_app}#{E:@omarchy_status_host}"

set -g status-format[0] "#[align=left fill=$surface]#[bg=$blue,fg=$bg,bold]#{T;=/#{status-left-length}:status-left}#[default]#{W:#{E:window-status-format},#{E:window-status-current-format}}#[align=right fill=$surface]#{T;=/#{status-right-length}:status-right}"
EOF
else
  cat >>"$tmp" <<EOF
# Dark themes: minimal cohesive status, no alternating heavy blocks.
set -g window-status-style "bg=$surface,fg=$subtle"
set -g window-status-format " #[fg=$subtle]#I #[fg=$subtle]#W "
set -g window-status-current-style "bg=$surface,fg=$fg,bold"
set -g window-status-current-format " #[fg=$yellow,bold]#I #[fg=$fg,bold]#W "
set -g window-status-bell-style "bg=$surface,fg=$yellow,bold"
set -g window-status-activity-style "bg=$surface,fg=$blue"

set -g status-left-style "bg=$surface,fg=$fg"
set -g status-left " #[fg=$blue,bold]#S "
set -g status-right-style "bg=$surface,fg=$fg"

set -g @omarchy_status_copy "#[fg=$yellow,bold] COPY #[fg=$fg]mode "
set -g @omarchy_status_prefix "#[fg=$red,bold] PREFIX #[fg=$fg]on "
set -g @omarchy_status_zoom "#[fg=$yellow,bold] ZOOM #[fg=$fg]pane "
set -g @omarchy_status_app "#[fg=$green,bold]  #[fg=$fg]#{pane_current_command} "
set -g @omarchy_status_host "#[fg=$blue,bold] 󰒋 #[fg=$fg]#H "
set -g status-right "#{?pane_in_mode,#{E:@omarchy_status_copy},}#{?client_prefix,#{E:@omarchy_status_prefix},}#{?window_zoomed_flag,#{E:@omarchy_status_zoom},}#{E:@omarchy_status_app}#{E:@omarchy_status_host}"

set -g status-format[0] "#[align=left fill=$surface]#{T;=/#{status-left-length}:status-left}#{W:#{E:window-status-format},#{E:window-status-current-format}}#[align=right fill=$surface]#{T;=/#{status-right-length}:status-right}"
EOF
fi

mv "$tmp" "$out_file"

if [[ "${TMUX_OMARCHY_NO_APPLY:-0}" != "1" ]] && command -v tmux >/dev/null 2>&1 && tmux list-sessions >/dev/null 2>&1; then
  tmux source-file "$out_file"
fi
