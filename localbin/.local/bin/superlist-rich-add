#!/usr/bin/env python3
import argparse
import json
import os
import secrets
import smtplib
import subprocess
import sys
import time
from email.message import EmailMessage
from pathlib import Path
from typing import Any

SMTP_TO = "task@mail.superlist.com"


def die(msg: str, code: int = 1) -> None:
    print(f"superlist-rich-add: {msg}", file=sys.stderr)
    raise SystemExit(code)


def run_superlist(*args: str) -> dict[str, Any]:
    env = os.environ.copy()
    env["SUPERLIST_RAW_JSON"] = "1"
    try:
        proc = subprocess.run(
            ["superlist", *args],
            check=True,
            capture_output=True,
            text=True,
            env=env,
        )
    except FileNotFoundError:
        die("missing 'superlist' CLI in PATH")
    except subprocess.CalledProcessError as e:
        msg = e.stderr.strip() or e.stdout.strip() or str(e)
        die(f"superlist {' '.join(args)} failed: {msg}")

    try:
        return json.loads(proc.stdout)
    except json.JSONDecodeError as e:
        die(f"could not parse JSON from superlist {' '.join(args)}: {e}")


def smtp_config() -> dict[str, Any]:
    cfg = {
        "host": os.environ.get("SUPERLIST_SMTP_HOST", "smtp.fastmail.com"),
        "port": int(os.environ.get("SUPERLIST_SMTP_PORT", "465")),
        "secure": os.environ.get("SUPERLIST_SMTP_SECURE", "true").lower() not in {"0", "false", "no"},
        "user": os.environ.get("SUPERLIST_SMTP_USER"),
        "password": os.environ.get("SUPERLIST_SMTP_PASS"),
        "from_addr": os.environ.get("SUPERLIST_SMTP_FROM") or os.environ.get("SUPERLIST_SMTP_USER"),
    }
    missing = [k for k in ("user", "password", "from_addr") if not cfg[k]]
    if missing:
        die(
            "missing SMTP env vars: "
            + ", ".join(f"SUPERLIST_SMTP_{name.upper() if name != 'from_addr' else 'FROM'}" for name in missing)
        )
    return cfg


def send_email(subject: str, body: str) -> None:
    cfg = smtp_config()
    msg = EmailMessage()
    msg["From"] = cfg["from_addr"]
    msg["To"] = SMTP_TO
    msg["Subject"] = subject
    msg.set_content(body if body else " ")

    if cfg["secure"]:
        with smtplib.SMTP_SSL(cfg["host"], cfg["port"], timeout=30) as smtp:
            smtp.login(cfg["user"], cfg["password"])
            smtp.send_message(msg)
    else:
        with smtplib.SMTP(cfg["host"], cfg["port"], timeout=30) as smtp:
            smtp.starttls()
            smtp.login(cfg["user"], cfg["password"])
            smtp.send_message(msg)


def load_body(args: argparse.Namespace) -> str:
    sources = sum(bool(x) for x in [args.body, args.body_file, args.stdin])
    if sources > 1:
        die("use only one of --body, --body-file or --stdin")
    if args.body is not None:
        return args.body
    if args.body_file is not None:
        return Path(args.body_file).read_text()
    if args.stdin:
        return sys.stdin.read()
    return ""


def list_uuid_from_arg(list_arg: str, create: bool) -> str:
    if len(list_arg) == 36 and list_arg.count("-") == 4:
        return list_arg

    lists = run_superlist("lists")
    items = lists.get("structuredContent", {}).get("lists", [])
    for item in items:
        if item.get("title") == list_arg:
            return item["uuid"]

    if create:
        created = run_superlist("call", "add_list", json.dumps({"title": list_arg}))
        new_list = created.get("structuredContent", {}).get("list") or created.get("_meta", {}).get("list")
        if new_list and new_list.get("uuid"):
            return new_list["uuid"]
        die(f"created list '{list_arg}' but did not receive a uuid")

    known = ", ".join(sorted(item.get("title", "") for item in items if item.get("title")))
    die(f"list not found: {list_arg}. Known lists: {known}")


def find_inbox_task_by_subject(subject: str, timeout: int, interval: float) -> dict[str, Any]:
    deadline = time.time() + timeout
    last_count = None
    while time.time() < deadline:
        inbox = run_superlist("inbox")
        tasks = inbox.get("structuredContent", {}).get("tasks", [])
        last_count = len(tasks)
        for task in tasks:
            if task.get("title") == subject:
                return task
        time.sleep(interval)
    die(f"timed out waiting for task to appear in Superlist Inbox (last inbox count: {last_count})")


def call_tool(name: str, payload: dict[str, Any]) -> dict[str, Any]:
    return run_superlist("call", name, json.dumps(payload))


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Create a Superlist task with rich markdown body via email, then refine it via MCP.")
    p.add_argument("--title", required=True, help="Task title")
    p.add_argument("--body", help="Markdown body")
    p.add_argument("--body-file", help="Read markdown body from file")
    p.add_argument("--stdin", action="store_true", help="Read markdown body from stdin")
    p.add_argument("--list", help="Destination list title or UUID")
    p.add_argument("--create-list", action="store_true", help="Create destination list if it does not exist")
    p.add_argument("--due", help="Due date in YYYY-MM-DD")
    p.add_argument("--priority", choices=["none", "low", "medium", "high"], default="none")
    p.add_argument("--label", action="append", default=[], help="Add label (repeatable)")
    p.add_argument("--assignee-email", help="Assign task to this email")
    p.add_argument("--timeout", type=int, default=45, help="Seconds to wait for Superlist Inbox ingestion")
    p.add_argument("--poll-interval", type=float, default=3.0, help="Polling interval while waiting for Inbox ingestion")
    p.add_argument("--keep-token", action="store_true", help="Keep the temporary correlation token in the final title")
    p.add_argument("--json", action="store_true", help="Output JSON summary")
    p.add_argument("--dry-run", action="store_true", help="Show what would happen without sending email or changing Superlist")
    return p.parse_args()


def main() -> None:
    args = parse_args()
    body = load_body(args)
    token = secrets.token_urlsafe(4).replace("-", "").replace("_", "")[:6]
    subject = f"{args.title} [sl:{token}]"
    final_title = subject if args.keep_token else args.title

    summary: dict[str, Any] = {
        "smtp_to": SMTP_TO,
        "subject": subject,
        "final_title": final_title,
        "body_length": len(body),
        "list": args.list,
        "due": args.due,
        "priority": args.priority,
        "labels": args.label,
        "assignee_email": args.assignee_email,
    }

    if args.dry_run:
        if args.json:
            print(json.dumps(summary, indent=2))
        else:
            print(json.dumps(summary, indent=2, ensure_ascii=False))
            if body:
                print("\n--- body preview ---\n")
                print(body)
        return

    send_email(subject, body)
    task = find_inbox_task_by_subject(subject, args.timeout, args.poll_interval)
    task_uuid = task.get("uuid")
    if not task_uuid:
        die("found task in inbox but no task uuid was returned")

    if final_title != subject:
        call_tool("update_task", {"task_uuid": task_uuid, "title": final_title})
    if args.due or args.priority != "none":
        payload: dict[str, Any] = {"task_uuid": task_uuid}
        if args.due:
            payload["due_date"] = args.due
        if args.priority != "none":
            payload["priority"] = args.priority
        call_tool("update_task", payload)
    if args.list:
        call_tool("move_task", {"task_uuid": task_uuid, "list_uuid": list_uuid_from_arg(args.list, args.create_list)})
    for label in args.label:
        call_tool("add_label", {"task_uuid": task_uuid, "label": label})
    if args.assignee_email:
        call_tool("assign_task", {"task_uuid": task_uuid, "assignee_email": args.assignee_email})

    result = {
        "task_uuid": task_uuid,
        "title": final_title,
        "body_length": len(body),
        "list": args.list,
        "due": args.due,
        "priority": args.priority,
        "labels": args.label,
        "assignee_email": args.assignee_email,
    }
    if args.json:
        print(json.dumps(result, indent=2))
    else:
        print(f"Created rich Superlist task: {task_uuid}")
        print(f"Title: {final_title}")
        if args.list:
            print(f"List: {args.list}")
        if args.due:
            print(f"Due: {args.due}")
        if args.priority != 'none':
            print(f"Priority: {args.priority}")
        if args.label:
            print("Labels: " + ", ".join(args.label))
        if args.assignee_email:
            print(f"Assignee: {args.assignee_email}")


if __name__ == "__main__":
    main()
