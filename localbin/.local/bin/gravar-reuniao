#!/bin/bash

set -euo pipefail

TIMESTAMP=$(date +%Y-%m-%d_%H%M)
OUTPUT_DIR="$HOME/Sync/Reunioes"
mkdir -p "$OUTPUT_DIR"
AUDIO_FILE="$OUTPUT_DIR/reuniao_${TIMESTAMP}.wav"
MIC_GAIN="${MIC_GAIN:-1.20}"
MONITOR_GAIN="${MONITOR_GAIN:-0.92}"
OUTPUT_RATE="${OUTPUT_RATE:-24000}"
MIC_FILTER="${MIC_FILTER:-highpass=f=80,lowpass=f=9000,afftdn=nf=-20,acompressor=threshold=0.09:ratio=3:attack=5:release=90:makeup=3,alimiter=limit=0.92}"

echo "🎙  A gravar reunião — Ctrl+C para parar"
echo "     Ficheiro: $AUDIO_FILE"
echo ""

# Captura áudio do sistema (PipeWire via PulseAudio compat)
MONITOR="$(pactl get-default-sink).monitor"
MIC="$(pactl get-default-source)"

echo "     Monitor : $MONITOR"
echo "     Microfone: $MIC"
echo ""
echo "  Antes de gravar, confirma:"
echo "  ✅ Estás a ouvir a reunião pelo dispositivo correto?"
echo "  ✅ O microfone está ligado?"
echo ""
read -rp "  Prima Enter para começar a gravar (Ctrl+C para cancelar)..."
echo ""

ffmpeg_pid=""
recording_stopped=false

stop_recording() {
  recording_stopped=true
  echo ""
  echo "⏹  A parar gravação..."
  [[ -n "${ffmpeg_pid:-}" ]] && kill "$ffmpeg_pid" 2>/dev/null || true
}

trap stop_recording INT

# Mistura monitor (outros participantes) + microfone (a tua voz)
# Afinamento leve para fala: high-pass, redução suave de ruído, compressão e limiter
ffmpeg -f pulse -i "$MONITOR" -f pulse -i "$MIC" \
    -filter_complex "[0:a]aformat=channel_layouts=mono,volume=${MONITOR_GAIN}[mon];[1:a]aformat=channel_layouts=mono,${MIC_FILTER},volume=${MIC_GAIN}[mic];[mon][mic]amix=inputs=2:duration=longest:normalize=0[mix];[mix]alimiter=limit=0.95[out]" \
    -map "[out]" -ar "$OUTPUT_RATE" -c:a pcm_s16le "$AUDIO_FILE" 2>/dev/null &
ffmpeg_pid=$!

set +e
wait "$ffmpeg_pid"
ffmpeg_status=$?
set -e

if [[ $ffmpeg_status -ne 0 && $recording_stopped != true ]]; then
  echo "Erro: a gravação terminou de forma inesperada." >&2
  exit "$ffmpeg_status"
fi

echo ""
echo "✅ Gravação terminada"
echo "   WAV: $AUDIO_FILE"
echo ""
echo "Para transcrever depois:"
printf 'PT: WHISPER_MODEL=large-v3 WHISPER_LANGUAGE=pt transcrever-reuniao "%s"\n' "$AUDIO_FILE"
printf 'EN: WHISPER_MODEL=large-v3 WHISPER_LANGUAGE=en transcrever-reuniao "%s"\n' "$AUDIO_FILE"
