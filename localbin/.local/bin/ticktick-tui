#!/usr/bin/env python3
"""Pretty TickTick TUI for Dias, built on top of the official TickTick CLI.

Requires:
  npm i -g @ticktick/ticktick-cli
  ticktick auth login   # or ticktick auth token <token>

This script intentionally does not implement the TickTick API directly.  The
official `ticktick` command is the engine; this is only a nice terminal UI.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import textwrap
from dataclasses import dataclass
from pathlib import Path
from datetime import date, datetime, timedelta, timezone
from typing import Any

try:
    from zoneinfo import ZoneInfo
except Exception:  # pragma: no cover
    ZoneInfo = None  # type: ignore

DEFAULT_TZ = os.environ.get("TICKTICK_TIMEZONE", "Europe/Lisbon")
TICKTICK_BIN = os.environ.get("TICKTICK_BIN", "ticktick")
INBOX_CACHE = Path(os.environ.get("TICKTICK_TUI_INBOX_CACHE", str(Path.home() / ".cache" / "ticktick-tui-inbox-id")))


class AppError(RuntimeError):
    pass


@dataclass
class Project:
    id: str
    name: str
    color: str
    raw: dict[str, Any]


@dataclass
class Task:
    id: str
    project_id: str
    project: str
    title: str
    content: str
    desc: str
    due_date: str | None
    start_date: str | None
    is_all_day: bool
    tz: str | None
    priority: int
    status: int
    tags: list[str]
    repeat: str | None
    parent_id: str | None
    raw: dict[str, Any]

    @property
    def local_date(self) -> date | None:
        return parse_tick_date(self.due_date or self.start_date, self.tz)

    @property
    def is_subtask(self) -> bool:
        return bool(self.parent_id)


# ---------- shell helpers -------------------------------------------------


def has(cmd: str) -> bool:
    return shutil.which(cmd) is not None


def run(args: list[str], *, json_out: bool = False, check: bool = True) -> Any:
    cmd = [TICKTICK_BIN, *args]
    proc = subprocess.run(cmd, text=True, capture_output=True)
    if check and proc.returncode != 0:
        msg = (proc.stderr or proc.stdout or "").strip()
        raise AppError(f"{' '.join(cmd)} falhou: {msg}")
    if json_out:
        text = proc.stdout.strip()
        return json.loads(text) if text else None
    return proc.stdout


def run_json(args: list[str]) -> Any:
    if "--json" not in args:
        args = [*args, "--json"]
    return run(args, json_out=True)


def gum(
    *args: str,
    input_text: str | None = None,
    interactive: bool = False,
) -> subprocess.CompletedProcess[str]:
    """Run gum.

    For interactive widgets, gum writes the visible interface to stderr and the
    selected value to stdout.  Capturing stderr hides the UI, so leave stderr
    attached to the terminal when interactive=True.
    """
    return subprocess.run(
        ["gum", *args],
        input=input_text,
        text=True,
        stdout=subprocess.PIPE,
        stderr=None if interactive else subprocess.PIPE,
    )


def style(
    text: str,
    *,
    fg: str = "212",
    bold: bool = False,
    border: bool = False,
    width: int | None = None,
) -> str:
    if not has("gum"):
        return text
    args = ["style", "--foreground", fg]
    if bold:
        args.append("--bold")
    if width:
        args += ["--width", str(width)]
    if border:
        args += ["--border", "rounded", "--border-foreground", fg, "--padding", "1 2", "--margin", "1 0"]
    proc = gum(*args, input_text=text)
    return proc.stdout.rstrip("\n") if proc.returncode == 0 else text


def clear_screen() -> None:
    if sys.stdout.isatty():
        # 2J clears the visible screen, 3J clears scrollback too.  Without 3J,
        # old detail cards can look like they are mixed with the current one.
        print("\033[2J\033[3J\033[H", end="", flush=True)


def content_width() -> int:
    columns = shutil.get_terminal_size((100, 24)).columns
    return max(60, min(96, columns - 12))


def wrap_text(text: str, width: int) -> list[str]:
    lines: list[str] = []
    for paragraph in text.splitlines():
        if not paragraph.strip():
            lines.append("")
            continue
        lines.extend(
            textwrap.wrap(
                paragraph,
                width=width,
                break_long_words=True,
                break_on_hyphens=True,
            )
        )
    return lines or [""]


def choose(header: str, options: list[str], *, filter_mode: bool = False) -> str | None:
    if not options:
        return None
    if has("gum"):
        if filter_mode:
            proc = gum(
                "filter",
                "--height",
                "20",
                "--placeholder",
                header,
                "--prompt",
                "󰍉 ",
                input_text="\n".join(options),
                interactive=True,
            )
        else:
            proc = gum("choose", "--header", header, "--height", "18", *options, interactive=True)
        if proc.returncode != 0:
            return None
        return proc.stdout.strip() or None

    print(header)
    for i, opt in enumerate(options, 1):
        print(f"{i:2d}. {opt}")
    while True:
        ans = input("Escolha> ").strip()
        if not ans:
            return None
        if ans.isdigit() and 1 <= int(ans) <= len(options):
            return options[int(ans) - 1]


def ask(prompt: str, default: str = "") -> str:
    if has("gum"):
        args = ["input", "--prompt", f"{prompt} "]
        if default:
            args += ["--value", default]
        proc = gum(*args, interactive=True)
        if proc.returncode == 0:
            return proc.stdout.strip()
        return default
    value = input(f"{prompt} [{default}] ").strip()
    return value or default


def confirm(prompt: str) -> bool:
    if has("gum"):
        return subprocess.run(["gum", "confirm", prompt]).returncode == 0
    return input(f"{prompt} [y/N] ").strip().lower() in {"y", "yes", "s", "sim"}


def pause() -> None:
    try:
        input("\nEnter para continuar...")
    except EOFError:
        pass


# ---------- data ----------------------------------------------------------


def auth_check() -> None:
    if not shutil.which(TICKTICK_BIN):
        raise AppError("CLI oficial TickTick não encontrado. Instala: npm install -g @ticktick/ticktick-cli")
    proc = subprocess.run([TICKTICK_BIN, "auth", "status"], text=True, capture_output=True)
    if proc.returncode != 0 or "Signed in" not in (proc.stdout + proc.stderr):
        raise AppError("TickTick CLI não autenticado. Corre: ticktick auth login")


def get_projects() -> list[Project]:
    raw = run_json(["project", "list"])
    return [Project(str(p["id"]), p.get("name", str(p["id"])), p.get("color") or "", p) for p in (raw or [])]


def project_name(project_id: str, project_map: dict[str, str]) -> str:
    if project_id.startswith("inbox"):
        return "Inbox"
    return project_map.get(project_id, project_id)


def get_open_tasks(projects: list[Project] | None = None) -> list[Task]:
    projects = projects or get_projects()
    project_map = {p.id: p.name for p in projects}
    raw = run_json(["task", "filter", "--status", "0"])
    tasks = [task_from_raw(t, project_map) for t in (raw or [])]
    tasks = [t for t in tasks if t.status == 0]
    return sorted(tasks, key=lambda t: (sort_date(t), -t.priority, t.project.lower(), t.title.lower()))


def navigation_projects(projects: list[Project], tasks: list[Task]) -> list[Project]:
    """Projects/lists visible in the TUI.

    TickTick's Open API/official CLI does not return Inbox in `project list`,
    but Inbox tasks still appear in `task filter` with projectId like
    `inbox123...`.  Treat that as a virtual project so Inbox is not hidden.
    Cache the observed Inbox id so the menu can still show Inbox (0) later.
    """
    existing = {p.id for p in projects}
    inbox_ids = sorted({t.project_id for t in tasks if t.project_id.startswith("inbox")})
    if inbox_ids:
        try:
            INBOX_CACHE.parent.mkdir(parents=True, exist_ok=True)
            INBOX_CACHE.write_text(inbox_ids[0])
        except OSError:
            pass
    else:
        try:
            cached = INBOX_CACHE.read_text().strip()
            if cached.startswith("inbox"):
                inbox_ids = [cached]
        except OSError:
            pass
    virtual = [Project(pid, "Inbox", "", {"id": pid, "name": "Inbox", "virtual": True}) for pid in inbox_ids if pid not in existing]
    return [*virtual, *projects]


def task_from_raw(raw: dict[str, Any], project_map: dict[str, str]) -> Task:
    pid = str(raw.get("projectId") or "")
    return Task(
        id=str(raw.get("id") or ""),
        project_id=pid,
        project=project_name(pid, project_map),
        title=raw.get("title") or "",
        content=raw.get("content") or "",
        desc=raw.get("desc") or "",
        due_date=raw.get("dueDate"),
        start_date=raw.get("startDate"),
        is_all_day=bool(raw.get("isAllDay")),
        tz=raw.get("timeZone"),
        priority=int(raw.get("priority") or 0),
        status=int(raw.get("status") or 0),
        tags=list(raw.get("tags") or []),
        repeat=raw.get("repeatFlag") or None,
        parent_id=raw.get("parentId") or None,
        raw=raw,
    )


def parse_tick_date(value: str | None, tz_name: str | None = None) -> date | None:
    if not value:
        return None
    dt: datetime | None = None
    for fmt in ("%Y-%m-%dT%H:%M:%S.%f%z", "%Y-%m-%dT%H:%M:%S%z"):
        try:
            dt = datetime.strptime(value, fmt)
            break
        except ValueError:
            pass
    if dt is None:
        try:
            return date.fromisoformat(value[:10])
        except Exception:
            return None
    return dt.astimezone(zone(tz_name or DEFAULT_TZ)).date()


def zone(name: str):
    if ZoneInfo is None:
        return timezone.utc
    try:
        return ZoneInfo(name)
    except Exception:
        return ZoneInfo(DEFAULT_TZ)


def tick_datetime_for_day(day: date) -> str:
    local = datetime(day.year, day.month, day.day, 0, 0, 0, tzinfo=zone(DEFAULT_TZ))
    utc = local.astimezone(timezone.utc)
    return utc.strftime("%Y-%m-%dT%H:%M:%S+0000")


def parse_due(value: str) -> date | None:
    v = value.strip().lower()
    if not v:
        return None
    today = date.today()
    if v in {"today", "hoje"}:
        return today
    if v in {"tomorrow", "amanhã", "amanha"}:
        return today + timedelta(days=1)
    if v in {"next week", "proxima semana", "próxima semana"}:
        return today + timedelta(days=7)
    return date.fromisoformat(v)


def sort_date(task: Task) -> date:
    return task.local_date or date.max


def due_text(task: Task) -> str:
    d = task.local_date
    if not d:
        return "sem data"
    today = date.today()
    if d == today:
        return "hoje"
    if d == today + timedelta(days=1):
        return "amanhã"
    return d.isoformat()


def priority_label(priority: int) -> str:
    return {5: "P1", 3: "P2", 1: "P3", 0: "P4"}.get(priority, f"P{priority}")


def parse_priority(value: str | None) -> int:
    if not value:
        return 0
    v = value.strip().upper().split()[0]
    return {"P1": 5, "1": 5, "HIGH": 5, "ALTA": 5, "P2": 3, "2": 3, "MÉDIA": 3, "MEDIA": 3, "P3": 1, "3": 1, "BAIXA": 1, "LOW": 1, "P4": 0, "4": 0, "NORMAL": 0, "NONE": 0, "0": 0}.get(v, 0)


def marker(task: Task) -> str:
    d = task.local_date
    today = date.today()
    if d and d < today:
        return "!"
    if d == today:
        return ">"
    if task.is_subtask:
        return "└"
    if task.repeat:
        return "~"
    return " "


def task_line(task: Task) -> str:
    tags = " ".join(f"#{t}" for t in task.tags)
    sub = "  └ " if task.is_subtask else ""
    rep = "  ~" if task.repeat else ""
    return f"{marker(task):<1}  {priority_label(task.priority):<2}  {due_text(task):<10}  {task.project:<10}  {sub}{task.title}{rep} {tags}  [{task.id}]"


def extract_id(line: str) -> str | None:
    match = re.search(r"\[([^\]]+)\]\s*$", line)
    return match.group(1) if match else None


def filter_tasks(tasks: list[Task], kind: str) -> list[Task]:
    today = date.today()
    if kind == "today":
        return [t for t in tasks if t.local_date == today]
    if kind == "overdue":
        return [t for t in tasks if t.local_date and t.local_date < today]
    if kind == "week":
        end = today + timedelta(days=7)
        return [t for t in tasks if t.local_date and today <= t.local_date <= end]
    if kind == "urgent":
        return [t for t in tasks if t.priority == 5 or (t.local_date and t.local_date <= today)]
    if kind == "p1p2":
        return [t for t in tasks if t.priority in {5, 3}]
    if kind == "nodate":
        return [t for t in tasks if not t.local_date]
    return tasks


# ---------- render --------------------------------------------------------


def render_dashboard(tasks: list[Task]) -> None:
    today = len(filter_tasks(tasks, "today"))
    overdue = len(filter_tasks(tasks, "overdue"))
    week = len(filter_tasks(tasks, "week"))
    urgent = len(filter_tasks(tasks, "urgent"))
    nodate = len(filter_tasks(tasks, "nodate"))
    total = len(tasks)
    title = "✨ TickTick cockpit"
    subtitle = f"● Hoje {today}  ·  🔥 Atrasadas {overdue}  ·  Semana {week}  ·  🚩 Urgentes {urgent}  ·  Sem data {nodate}  ·  Total {total}"
    print(style(f"{title}\n{subtitle}", fg="212", bold=True, border=True))


def print_tasks(tasks: list[Task], *, json_output: bool = False) -> None:
    if json_output:
        print(json.dumps([t.raw for t in tasks], ensure_ascii=False, indent=2))
        return
    if not tasks:
        print(style("Sem tarefas.", fg="82", bold=True))
        return
    for task in tasks:
        print(task_line(task))


def detail_card(task: Task) -> str:
    width = content_width()
    lines = wrap_text(task.title, width)
    lines += [
        "",
        f"Lista:      {task.project}",
        f"Prioridade: {priority_label(task.priority)}",
        f"Data:       {due_text(task)}",
    ]
    if task.tags:
        lines.append("Tags:       " + " ".join(f"#{t}" for t in task.tags))
    if task.repeat:
        lines.append(f"Recorre:    {task.repeat}")
    if task.parent_id:
        lines.append(f"Parent:     {task.parent_id}")
    note = task.content or task.desc
    if note:
        lines += ["", "Notas:", *wrap_text(note[:1200], width)]
    lines += ["", f"ID: {task.id}"]
    return style("\n".join(lines), fg="99", border=True, width=width)


# ---------- actions -------------------------------------------------------


def complete_task(task: Task) -> None:
    run(["task", "complete", task.project_id, task.id])


def update_date(task: Task, day: date) -> None:
    value = tick_datetime_for_day(day)
    run([
        "task",
        "update",
        task.id,
        "--id",
        task.id,
        "--project",
        task.project_id,
        "--all-day",
        "--start-date",
        value,
        "--due-date",
        value,
        "--time-zone",
        DEFAULT_TZ,
    ])


def update_priority(task: Task, priority: int) -> None:
    run(["task", "update", task.id, "--id", task.id, "--project", task.project_id, "--priority", str(priority)])


def link_parent(task: Task, parent_id: str | None) -> None:
    value = parent_id or "null"
    run(["task", "update", task.id, "--id", task.id, "--project", task.project_id, "--parent-id", value])


def move_task(task: Task, project: Project) -> None:
    run(["task", "move", "--from", task.project_id, "--to", project.id, "--task", task.id])


def create_task(project: Project, title: str, content: str, due: date | None, priority: int, tags: list[str]) -> None:
    args = ["task", "create", "--title", title, "--project", project.id, "--priority", str(priority)]
    if content:
        args += ["--content", content, "--desc", content]
    if due:
        value = tick_datetime_for_day(due)
        args += ["--all-day", "--start-date", value, "--due-date", value, "--time-zone", DEFAULT_TZ]
    if tags:
        args += ["--tags", ",".join(t.lstrip("#") for t in tags)]
    run(args)


def task_actions(task: Task, tasks: list[Task]) -> None:
    while True:
        clear_screen()
        print(detail_card(task))
        action = choose(
            "Tarefa · ações",
            [
                "Concluir",
                "Mudar data",
                "Mudar prioridade",
                "Mover para lista",
                "────────────",
                "Ligar parent",
                "Remover parent",
                "Voltar",
            ],
        )
        if not action or action == "Voltar":
            return
        if action.startswith("─"):
            continue
        if action == "Concluir":
            if confirm(f"Concluir '{task.title}'?"):
                complete_task(task)
                print(style("OK · concluída", fg="82", bold=True))
                pause()
                return
        elif action == "Mudar data":
            option = choose("Nova data", ["Hoje", "Amanhã", "Próxima semana", "Custom YYYY-MM-DD", "Voltar"])
            if not option or option == "Voltar":
                continue
            if option == "Hoje":
                day = date.today()
            elif option == "Amanhã":
                day = date.today() + timedelta(days=1)
            elif option == "Próxima semana":
                day = date.today() + timedelta(days=7)
            else:
                day = parse_due(ask("Data", date.today().isoformat()))
                if day is None:
                    continue
            update_date(task, day)
            print(style("OK · data atualizada", fg="82", bold=True))
            pause()
            return
        elif action == "Mudar prioridade":
            option = choose("Prioridade", ["P1 alta", "P2 média", "P3 baixa", "P4 normal", "Voltar"])
            if not option or option == "Voltar":
                continue
            update_priority(task, parse_priority(option))
            print(style("OK · prioridade atualizada", fg="82", bold=True))
            pause()
            return
        elif action == "Mover para lista":
            projects = [p for p in get_projects() if p.id != task.project_id]
            row = choose("Mover para", [f"{p.name} [{p.id}]" for p in projects])
            pid = extract_id(row or "")
            project = next((p for p in projects if p.id == pid), None)
            if project:
                move_task(task, project)
                print(style(f"OK · movida para {project.name}", fg="82", bold=True))
                pause()
                return
        elif action == "Ligar parent":
            candidates = [t for t in tasks if t.project_id == task.project_id and t.id != task.id]
            rows = [task_line(t) for t in candidates]
            selected = choose("Parent task", rows, filter_mode=True)
            parent_id = extract_id(selected or "")
            if parent_id:
                link_parent(task, parent_id)
                print(style("OK · parent ligado", fg="82", bold=True))
                pause()
                return
        elif action == "Remover parent":
            if confirm("Remover parent desta task?"):
                link_parent(task, None)
                print(style("OK · parent removido", fg="82", bold=True))
                pause()
                return


def browse(title: str, tasks: list[Task], all_tasks: list[Task]) -> None:
    while True:
        rows = ["Voltar ao início"] + [task_line(t) for t in tasks]
        selected = choose(title, rows, filter_mode=True)
        if not selected or selected == "Voltar ao início":
            return
        task_id = extract_id(selected)
        task = next((t for t in all_tasks if t.id == task_id), None)
        if task:
            task_actions(task, all_tasks)
            # reload after mutation
            projects = get_projects()
            all_tasks[:] = get_open_tasks(projects)
            return


def add_flow(projects: list[Project]) -> None:
    title = ask("Tarefa")
    if not title:
        return
    content = ask("Notas", "")
    due_raw = ask("Data (hoje/amanhã/YYYY-MM-DD/opcional)", "")
    due = parse_due(due_raw) if due_raw else None
    priority = parse_priority(choose("Prioridade", ["P4 normal", "P3 baixa", "P2 média", "P1 alta"]) or "P4")
    tags_raw = ask("Tags sem #", "")
    tags = [t.strip().lstrip("#") for t in tags_raw.split() if t.strip()]
    project_row = choose("Lista", [f"{p.name} [{p.id}]" for p in projects])
    project_id = extract_id(project_row or "")
    project = next((p for p in projects if p.id == project_id), projects[0])
    create_task(project, title, content, due, priority, tags)
    print(style("OK · tarefa criada", fg="82", bold=True))
    pause()


def main_menu() -> None:
    auth_check()
    while True:
        projects = get_projects()
        tasks = get_open_tasks(projects)
        clear_screen()
        render_dashboard(tasks)
        today_count = len(filter_tasks(tasks, "today"))
        overdue_count = len(filter_tasks(tasks, "overdue"))
        week_count = len(filter_tasks(tasks, "week"))
        p1p2_count = len(filter_tasks(tasks, "p1p2"))
        nodate_count = len(filter_tasks(tasks, "nodate"))
        nav_projects = navigation_projects(projects, tasks)
        counts = {p.id: len([t for t in tasks if t.project_id == p.id]) for p in nav_projects}
        project_choices = {f"{p.name} ({counts.get(p.id, 0)})": p for p in nav_projects}
        choice = choose(
            "Menu principal",
            [
                f"Hoje ({today_count})",
                f"🔥 Atrasadas ({overdue_count})",
                f"Esta semana ({week_count})",
                f"🚩 P1/P2 ({p1p2_count})",
                f"Sem data ({nodate_count})",
                "────────────",
                *project_choices.keys(),
                "────────────",
                "+ Adicionar tarefa",
                "Auth status",
                "Sair",
            ],
        )
        if not choice or choice == "Sair":
            return
        if choice.startswith("─"):
            continue
        if choice.startswith("Hoje"):
            browse("Hoje", filter_tasks(tasks, "today"), tasks)
        elif "Atrasadas" in choice:
            browse("Atrasadas", filter_tasks(tasks, "overdue"), tasks)
        elif choice.startswith("Esta semana"):
            browse("Esta semana", filter_tasks(tasks, "week"), tasks)
        elif "P1/P2" in choice:
            browse("P1/P2", filter_tasks(tasks, "p1p2"), tasks)
        elif choice.startswith("Sem data"):
            browse("Sem data", filter_tasks(tasks, "nodate"), tasks)
        elif choice in project_choices:
            project = project_choices[choice]
            browse(project.name, [t for t in tasks if t.project_id == project.id], tasks)
        elif choice.endswith("Adicionar tarefa"):
            add_flow(nav_projects)
        elif choice.endswith("Auth status"):
            print(run(["auth", "status"], check=False))
            pause()


# ---------- CLI shortcuts -------------------------------------------------


def print_kind(kind: str, json_output: bool) -> None:
    auth_check()
    projects = get_projects()
    tasks = get_open_tasks(projects)
    print_tasks(filter_tasks(tasks, kind), json_output=json_output)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Pretty TickTick TUI over official ticktick CLI")
    sub = parser.add_subparsers(dest="cmd")
    for name in ["dashboard", "today", "overdue", "week", "urgent", "p1p2", "nodate", "list"]:
        p = sub.add_parser(name)
        p.add_argument("--json", action="store_true")
    return parser


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    try:
        if not argv:
            main_menu()
            return 0
        parser = build_parser()
        args = parser.parse_args(argv)
        if args.cmd == "dashboard":
            auth_check()
            render_dashboard(get_open_tasks(get_projects()))
        elif args.cmd == "list":
            print_kind("", args.json)
        elif args.cmd in {"today", "overdue", "week", "urgent", "p1p2", "nodate"}:
            print_kind(args.cmd, args.json)
        else:
            main_menu()
        return 0
    except AppError as exc:
        print(style(f"Erro: {exc}", fg="196", bold=True), file=sys.stderr)
        return 1
    except KeyboardInterrupt:
        print()
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
