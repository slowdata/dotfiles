#!/usr/bin/env bash
set -euo pipefail

API_BASE="https://api.todoist.com/api/v1"
DEFAULT_LIMIT="100"

has() { command -v "$1" >/dev/null 2>&1; }
interactive_tty() { [[ -r /dev/tty && -w /dev/tty ]]; }
use_gum() { has gum && interactive_tty; }

style() {
  if use_gum; then gum style --foreground 212 --bold "$@"; else printf '%s\n' "$*"; fi
}

info() { printf 'ℹ️  %s\n' "$*"; }
warn() { printf '⚠️  %s\n' "$*" >&2; }
err() { printf '❌ %s\n' "$*" >&2; }

pause() {
  if [[ -r /dev/tty ]]; then
    printf '\n' >/dev/tty
    read -rp "Enter para continuar..." _ </dev/tty || true
  else
    printf '\n'
    read -rp "Enter para continuar..." _ || true
  fi
}

confirm() {
  local prompt="$1" answer
  if use_gum; then
    gum confirm "$prompt" </dev/tty >/dev/tty
  else
    if [[ -r /dev/tty ]]; then
      read -rp "$prompt [y/N] " answer </dev/tty
    else
      read -rp "$prompt [y/N] " answer
    fi
    [[ "${answer,,}" == "y" || "${answer,,}" == "yes" || "${answer,,}" == "s" || "${answer,,}" == "sim" ]]
  fi
}

choose() {
  local header="$1"; shift
  if use_gum; then
    gum choose --header "$header" --height 18 "$@" </dev/tty
  elif interactive_tty; then
    local options=("$@") opt
    echo "$header" >/dev/tty
    select opt in "${options[@]}"; do
      [[ -n "${opt:-}" ]] && { printf '%s\n' "$opt"; return 0; }
    done </dev/tty
  else
    err "Esta ação precisa de um terminal interativo."
    printf '%s\n' "$header"
    printf '  %s\n' "$@"
    return 1
  fi
}

filter_choose() {
  local header="$1"; shift
  if use_gum; then
    printf '%s\n' "$@" | gum filter --height 20 --placeholder "$header" --prompt "󰍉 "
  else
    choose "$header" "$@"
  fi
}

input() {
  local prompt="$1" default="${2:-}" value
  if use_gum; then
    gum input --prompt "$prompt " --value "$default" </dev/tty
  elif interactive_tty; then
    read -rp "$prompt [$default] " value </dev/tty
    printf '%s\n' "${value:-$default}"
  else
    err "Input interativo indisponível: $prompt"
    return 1
  fi
}

require_token() {
  if [[ -z ${TODOIST_API_TOKEN:-} ]]; then
    err "Variável TODOIST_API_TOKEN não definida."
    echo "Sugestão: export TODOIST_API_TOKEN='...' em ~/.zshrc.local" >&2
    exit 1
  fi
}

todoist_api() {
  local method="$1" path="$2" data="${3:-}"
  local -a args=(
    -fsS
    -X "$method"
    "$API_BASE$path"
    -H "Authorization: Bearer ${TODOIST_API_TOKEN}"
    -H "Content-Type: application/json"
  )
  if [[ -n "$data" ]]; then
    args+=(--data "$data")
  fi
  curl "${args[@]}"
}

get_projects_json() {
  todoist_api GET "/projects"
}

get_tasks_json() {
  local filter="${1:-}" limit="${2:-$DEFAULT_LIMIT}"
  if [[ -n "$filter" ]]; then
    curl -fsS -G "$API_BASE/tasks/filter" \
      -H "Authorization: Bearer ${TODOIST_API_TOKEN}" \
      -H "Content-Type: application/json" \
      --data-urlencode "query=${filter}" \
      --data-urlencode "limit=${limit}"
  else
    curl -fsS -G "$API_BASE/tasks" \
      -H "Authorization: Bearer ${TODOIST_API_TOKEN}" \
      -H "Content-Type: application/json" \
      --data-urlencode "limit=${limit}"
  fi
}

get_task_json() {
  local task_id="$1"
  todoist_api GET "/tasks/$task_id"
}

update_task() {
  local task_id="$1" data="$2"
  todoist_api POST "/tasks/$task_id" "$data" >/dev/null
}

close_task() {
  local task_id="$1"
  todoist_api POST "/tasks/$task_id/close" >/dev/null
}

quick_add_task() {
  local text="$1" payload
  payload=$(TEXT="$text" python3 <<'PY'
import json, os
print(json.dumps({"text": os.environ["TEXT"]}, ensure_ascii=False))
PY
)
  todoist_api POST "/tasks/quick" "$payload"
}

json_update_payload() {
  python3 <<'PY'
import json, os
payload = {}
if os.environ.get("DUE_STRING"):
    payload["due_string"] = os.environ["DUE_STRING"]
if os.environ.get("DUE_LANG"):
    payload["due_lang"] = os.environ["DUE_LANG"]
if os.environ.get("PRIORITY"):
    payload["priority"] = int(os.environ["PRIORITY"])
print(json.dumps(payload, ensure_ascii=False))
PY
}

priority_num_to_label() {
  case "$1" in
    4) printf 'P1' ;;
    3) printf 'P2' ;;
    2) printf 'P3' ;;
    1|0|"") printf 'P4' ;;
    *) printf 'P%s' "$1" ;;
  esac
}

projects_cache() {
  if [[ -z ${_TODOIST_PROJECTS_JSON:-} ]]; then
    _TODOIST_PROJECTS_JSON="$(get_projects_json)"
  fi
  printf '%s' "$_TODOIST_PROJECTS_JSON"
}

project_name_by_id() {
  local project_id="$1"
  PROJECTS_JSON="$(projects_cache)" PROJECT_ID="$project_id" python3 <<'PY'
import json, os
projects = json.loads(os.environ['PROJECTS_JSON'])
project_id = os.environ['PROJECT_ID']
if isinstance(projects, dict):
    projects = projects.get('results', [])
for p in projects:
    if str(p.get('id')) == project_id:
        print(p.get('name', project_id))
        raise SystemExit(0)
print(project_id)
PY
}

project_rows() {
  PROJECTS_JSON="$(projects_cache)" python3 <<'PY'
import json, os
projects = json.loads(os.environ['PROJECTS_JSON'])
if isinstance(projects, dict):
    projects = projects.get('results', [])
for p in projects:
    print(f"[{p.get('id','')}] {p.get('name','')}")
PY
}

task_rows_from_json() {
  local tasks_json="$1"
  local projects_json="$2"
  TASKS_JSON="$tasks_json" PROJECTS_JSON="$projects_json" python3 <<'PY'
import json, os
raw = json.loads(os.environ['TASKS_JSON'])
projects_raw = json.loads(os.environ['PROJECTS_JSON'])
tasks = raw if isinstance(raw, list) else raw.get('results', [])
projects = projects_raw if isinstance(projects_raw, list) else projects_raw.get('results', [])
project_map = {str(p.get('id')): p.get('name','') for p in projects}
task_map = {str(t.get('id')): t for t in tasks}

def priority_label(value):
    return {4:'P1',3:'P2',2:'P3',1:'P4'}.get(value, f'P{value}')

for task in tasks:
    tid = task.get('id','')
    content = ' '.join(str(task.get('content','')).split())
    parent_id = task.get('parent_id')
    parent = task_map.get(str(parent_id)) if parent_id else None
    prefix = '↳ ' if parent_id else '  '
    if parent:
        parent_title = ' '.join(str(parent.get('content','')).split())
        content = f"{prefix}{content}  < {parent_title}"
    else:
        content = f"{prefix}{content}"
    due = (task.get('due') or {}).get('string') or (task.get('due') or {}).get('date') or 'sem data'
    project = project_map.get(str(task.get('project_id','')), str(task.get('project_id','')))
    priority = priority_label(task.get('priority', 1))
    labels = task.get('labels') or []
    label_text = f" | labels:{','.join(labels)}" if labels else ''
    print(f"{priority:<2}  {due:<14}  {project:<12}  {content}  [{tid}]{label_text}")
PY
}

pick_task_from_json() {
  local header="$1" tasks_json="$2" rows
  rows="$(task_rows_from_json "$tasks_json" "$(projects_cache)")"
  if [[ -z "$rows" ]]; then
    warn "Sem tarefas."
    pause
    return 1
  fi
  mapfile -t options <<<"$rows"
  filter_choose "$header" "↩ Início" "${options[@]}"
}

task_id_from_row() {
  local row="$1"
  [[ "$row" =~ \[([^]]+)\]($|[[:space:]]\|) ]] || return 1
  printf '%s\n' "${BASH_REMATCH[1]}"
}

show_task_details() {
  local task_id="$1" task_json all_tasks_json
  task_json="$(get_task_json "$task_id")"
  all_tasks_json="$(get_tasks_json "" "300")"
  TASK_JSON="$task_json" ALL_TASKS_JSON="$all_tasks_json" PROJECTS_JSON="$(projects_cache)" python3 <<'PY'
import json, os
raw = json.loads(os.environ['TASK_JSON'])
projects_raw = json.loads(os.environ['PROJECTS_JSON'])
projects = projects_raw if isinstance(projects_raw, list) else projects_raw.get('results', [])
project_map = {str(p.get('id')): p.get('name','') for p in projects}
task = raw.get('task', raw) if isinstance(raw, dict) else raw
priority = {4:'P1',3:'P2',2:'P3',1:'P4'}.get(task.get('priority',1), str(task.get('priority','')))
due = (task.get('due') or {}).get('string') or (task.get('due') or {}).get('date') or 'sem data'
project = project_map.get(str(task.get('project_id','')), str(task.get('project_id','')))
labels = ', '.join(task.get('labels') or []) or '—'
print(task.get('content',''))
print('=' * len(task.get('content','')))
print(f"ID: {task.get('id','')}")
if task.get('parent_id'):
    print(f"Parent ID: {task.get('parent_id')}")
print(f"Projeto: {project}")
print(f"Prioridade: {priority}")
print(f"Due: {due}")
print(f"Labels: {labels}")
desc = task.get('description') or ''
if desc:
    print("\nDescrição:\n")
    print(desc)

raw_tasks = json.loads(os.environ['ALL_TASKS_JSON'])
all_tasks = raw_tasks if isinstance(raw_tasks, list) else raw_tasks.get('results', [])
children = [t for t in all_tasks if str(t.get('parent_id') or '') == str(task.get('id'))]
if children:
    print("\nSubtarefas:\n")
    for child in sorted(children, key=lambda t: t.get('child_order') or 0):
        c_priority = {4:'P1',3:'P2',2:'P3',1:'P4'}.get(child.get('priority',1), str(child.get('priority','')))
        c_due = (child.get('due') or {}).get('string') or (child.get('due') or {}).get('date') or 'sem data'
        print(f"- [ ] {child.get('content','')}  — {c_priority} | {c_due} | {child.get('id','')}")
PY
  pause
}

complete_task_flow() {
  local task_id="$1" label="$2"
  confirm "Concluir '$label'?" || return 0
  close_task "$task_id"
  info "Tarefa concluída."
  pause
}

set_due_flow() {
  local task_id="$1" choice due payload
  choice="$(choose "Adiar / data" "Amanhã" "Próxima semana" "Sem data" "Custom" "↩ Início" "Voltar")" || return 0
  case "$choice" in
    "Amanhã") due="tomorrow" ;;
    "Próxima semana") due="next week" ;;
    "Sem data") due="no date" ;;
    "Custom") due="$(input "Due Todoist" "tomorrow")" ;;
    "↩ Início") return ;;
    "Voltar") return ;;
  esac
  [[ -n "${due:-}" ]] || return
  payload="$(DUE_STRING="$due" DUE_LANG="en" json_update_payload)"
  update_task "$task_id" "$payload"
  info "Data atualizada: $due"
  pause
}

set_priority_flow() {
  local task_id="$1" choice priority payload
  choice="$(choose "Prioridade" "P1 alta" "P2" "P3" "P4 normal" "↩ Início" "Voltar")" || return 0
  case "$choice" in
    "P1 alta") priority="4" ;;
    "P2") priority="3" ;;
    "P3") priority="2" ;;
    "P4 normal") priority="1" ;;
    "↩ Início") return ;;
    "Voltar") return ;;
  esac
  payload="$(PRIORITY="$priority" json_update_payload)"
  update_task "$task_id" "$payload"
  info "Prioridade atualizada: ${choice}"
  pause
}

task_actions() {
  local row="$1" task_id label action
  task_id="$(task_id_from_row "$row")" || { err "Não consegui obter o ID da tarefa."; pause; return; }
  label="$row"
  while true; do
    action="$(choose "Ação" "Ver detalhes" "Concluir" "Adiar / data" "Mudar prioridade" "↩ Início" "Voltar")" || return 0
    case "$action" in
      "Ver detalhes") show_task_details "$task_id" ;;
      "Concluir") complete_task_flow "$task_id" "$label"; return ;;
      "Adiar / data") set_due_flow "$task_id" ; return ;;
      "Mudar prioridade") set_priority_flow "$task_id" ; return ;;
      "↩ Início") return ;;
      "Voltar") return ;;
    esac
  done
}

browse_filter() {
  local title="$1" filter="$2" tasks_json row
  tasks_json="$(get_tasks_json "$filter")"
  row="$(pick_task_from_json "$title" "$tasks_json")" || return 0
  [[ "$row" == "↩ Início" ]] && return 0
  task_actions "$row"
}

browse_project() {
  local row project_id project_name tasks_json selected
  mapfile -t projects < <(project_rows)
  (( ${#projects[@]} > 0 )) || { warn "Sem projetos."; pause; return; }
  row="$(choose "Projeto" "↩ Início" "${projects[@]}")" || return 0
  [[ "$row" == "↩ Início" ]] && return 0
  [[ "$row" =~ ^\[([^]]+)\]\ (.*)$ ]] || { err "Projeto inválido."; pause; return; }
  project_id="${BASH_REMATCH[1]}"
  project_name="${BASH_REMATCH[2]}"
  tasks_json="$(get_tasks_json "" "200")"
  selected="$(PROJECT_ID="$project_id" TASKS_JSON="$tasks_json" python3 <<'PY'
import json, os
project_id = os.environ['PROJECT_ID']
raw = json.loads(os.environ['TASKS_JSON'])
tasks = raw if isinstance(raw, list) else raw.get('results', [])
sel = [t for t in tasks if str(t.get('project_id')) == project_id]
print(json.dumps(sel, ensure_ascii=False))
PY
)"
  local task_row
  task_row="$(pick_task_from_json "Projeto: $project_name" "$selected")" || return 0
  [[ "$task_row" == "↩ Início" ]] && return 0
  task_actions "$task_row"
}

add_task_flow() {
  local title desc due priority project_row project_id result
  title="$(input "Título" "")"
  [[ -n "$title" ]] || { warn "Título vazio. Nada a fazer."; pause; return; }
  desc="$(input "Descrição (opcional)" "")"
  due="$(input "Due (opcional, ex: tomorrow / in 1 week)" "")"
  priority="$(choose "Prioridade" "4 (normal)" "3" "2" "1 (alta)" "↩ Início")" || return 0
  [[ "$priority" == "↩ Início" ]] && return 0
  priority="${priority%% *}"
  mapfile -t projects < <(project_rows)
  project_row="$(choose "Projeto" "↩ Início" "(sem projeto / Inbox)" "${projects[@]}")" || return 0
  [[ "$project_row" == "↩ Início" ]] && return 0
  project_id=""
  if [[ "$project_row" != "(sem projeto / Inbox)" ]]; then
    [[ "$project_row" =~ ^\[([^]]+)\] ]] && project_id="${BASH_REMATCH[1]}"
  fi

  local -a cmd=(todoist-add "$title")
  [[ -n "$desc" ]] && cmd+=(--desc "$desc")
  [[ -n "$due" ]] && cmd+=(--due "$due")
  [[ -n "$project_id" ]] && cmd+=(--project "$project_id")
  [[ -n "$priority" ]] && cmd+=(--priority "$priority")

  echo
  "${cmd[@]}"
  pause
}

quick_add_flow() {
  local text response
  text="$(input "Captura rápida Todoist" "")"
  [[ -n "$text" ]] || { warn "Texto vazio. Nada a fazer."; pause; return; }
  response="$(quick_add_task "$text")"
  RESPONSE="$response" python3 <<'PY'
import json, os
resp = json.loads(os.environ["RESPONSE"])
print("Tarefa criada com sucesso")
print(f"- conteúdo: {resp.get('content', '')}")
due = resp.get('due') or {}
if due:
    print(f"- due: {due.get('string') or due.get('date')}")
PY
  pause
}

custom_filter_flow() {
  local filter
  filter="$(input "Filtro Todoist" "today | overdue")"
  [[ -n "$filter" ]] || return
  browse_filter "Filtro: $filter" "$filter"
}

main_menu() {
  local choice
  while true; do
    clear
    if use_gum; then
      gum style --border rounded --padding "0 2" --foreground 212 --bold "Todoist TUI"
    else
      style "Todoist TUI"
    fi
    echo
    choice="$(choose "Escolhe uma vista" \
      "Hoje" \
      "Atrasadas" \
      "Esta semana" \
      "P1/P2" \
      "Sem data" \
      "Inbox" \
      "Por projeto" \
      "Filtro custom" \
      "Captura rápida" \
      "Adicionar detalhada" \
      "Sair")" || break
    case "$choice" in
      "Hoje") browse_filter "Hoje" "today" ;;
      "Atrasadas") browse_filter "Atrasadas" "overdue" ;;
      "Esta semana") browse_filter "Esta semana" "7 days" ;;
      "P1/P2") browse_filter "P1/P2" "p1 | p2" ;;
      "Sem data") browse_filter "Sem data" "no date" ;;
      "Inbox") browse_filter "Inbox" "#Inbox" ;;
      "Por projeto") browse_project ;;
      "Filtro custom") custom_filter_flow ;;
      "Captura rápida") quick_add_flow ;;
      "Adicionar detalhada") add_task_flow ;;
      "Sair") break ;;
    esac
  done
}

usage() {
  cat <<'EOF'
Usage:
  todoist-tui

Abre uma TUI simples para navegar e gerir tarefas da Todoist.

Requer:
  TODOIST_API_TOKEN
EOF
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

require_token
main_menu
